---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = 'AniTube Buzz — Anime News, Reviews & Streaming Guide',
  description = 'Your premium source for anime news, episode recaps, manga updates and streaming guides.',
  image = '/og-default.jpg',
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://anime-streaming-buzz.pages.dev');
const fullTitle = title.includes('AniTube') ? title : `${title} | AniTube Buzz`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="AniTube Buzz" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800;12..96,900&family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <script is:inline>
    (function(){
      var saved = localStorage.getItem('theme');
      if(saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>

<body>

  <!-- Loader -->
  <div id="loader">
    <div class="ld-brand">
      <span class="logo-ani">Ani</span><span class="logo-tube">Tube</span><span class="logo-buzz">Buzz</span>
    </div>
    <div class="ld-track"><div class="ld-bar"></div></div>
  </div>

  <!-- Anime Background (rotating) -->
  <div id="anime-bg" aria-hidden="true">
    <div class="abg-slide abg-active" id="abg-1"></div>
    <div class="abg-slide" id="abg-2"></div>
    <div class="abg-dark"></div>
    <div class="abg-gradient"></div>
  </div>

  <!-- App -->
  <div id="app">
    <slot name="header" />
    <main><slot /></main>
    <slot name="footer" />
  </div>

  <!-- Back to Top -->
  <button id="btt" aria-label="Scroll to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <script is:inline>
  (function(){
    // Loader
    window.addEventListener('load', function(){
      setTimeout(function(){
        var l = document.getElementById('loader');
        if(l){ l.style.opacity='0'; setTimeout(function(){ l.style.display='none'; },500); }
      }, 600);
    });

    // Back to top
    var btt = document.getElementById('btt');
    if(btt){
      window.addEventListener('scroll',function(){
        var show = window.scrollY > 400;
        btt.style.opacity = show ? '1' : '0';
        btt.style.pointerEvents = show ? 'auto' : 'none';
      });
      btt.addEventListener('click',function(){ window.scrollTo({top:0,behavior:'smooth'}); });
    }

    // Anime Background Slideshow
    var slide1 = document.getElementById('abg-1');
    var slide2 = document.getElementById('abg-2');
    var activeSlide = slide1;
    var current = 0;
    var images = [];

    function preload(url, cb){
      var img = new Image();
      img.onload = function(){ cb(true); };
      img.onerror = function(){ cb(false); };
      img.src = url;
    }

    function rotate(){
      if(images.length <= 1) return;
      current = (current + 1) % images.length;
      var inactive = (activeSlide === slide1) ? slide2 : slide1;
      preload(images[current].url, function(ok){
        if(!ok){ setTimeout(rotate, 100); return; }
        inactive.style.backgroundImage = 'url(' + images[current].url + ')';
        setTimeout(function(){
          inactive.classList.add('abg-active');
          activeSlide.classList.remove('abg-active');
          activeSlide = inactive;
        }, 100);
      });
    }

    function startBg(){
      if(!slide1 || images.length === 0) return;
      images.sort(function(){ return Math.random() - 0.5; });
      preload(images[0].url, function(ok){
        if(ok) slide1.style.backgroundImage = 'url(' + images[0].url + ')';
      });
      if(images.length > 1) setInterval(rotate, 15000);
    }

    // Load meta.json first
    fetch('/bg/meta.json')
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(meta){
        if(meta && meta.images && meta.images.length > 0){
          images = meta.images.map(function(img){
            return { url: '/bg/' + img.filename };
          });
          startBg();
        } else {
          fallback();
        }
      })
      .catch(fallback);

    function fallback(){
      var cands = [];
      for(var i = 1; i <= 15; i++) cands.push('/bg/bg' + i + '.jpg');
      var checked = 0;
      cands.forEach(function(url){
        preload(url, function(ok){
          checked++;
          if(ok) images.push({ url: url });
          if(checked === cands.length && images.length > 0) startBg();
        });
      });
    }
  })();
  </script>

</body>
</html>

<style is:global>
  /* ═══ RESET ═══ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  /* ═══ DARK THEME ═══ */
  [data-theme="dark"] {
    --bg-primary:    #0a0510;
    --bg-secondary:  #12081e;
    --bg-glass:      rgba(10, 5, 16, 0.7);
    --bg-card:       rgba(18, 8, 30, 0.6);
    --bg-card-hover: rgba(28, 14, 44, 0.75);

    --text-primary:   #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.72);
    --text-muted:     rgba(255, 255, 255, 0.45);
    --text-faint:     rgba(255, 255, 255, 0.2);

    --border-color:  rgba(255, 51, 102, 0.15);
    --border-hover:  rgba(255, 51, 102, 0.4);

    --accent-pink:      #ff3366;
    --accent-pink-hot:  #ff0080;
    --accent-cyan:      #00d4ff;
    --accent-purple:    #a855f7;
    --accent-gradient:  linear-gradient(135deg, #ff3366, #ff0080);
    --accent-cyan-glow: 0 0 20px rgba(0, 212, 255, 0.5);
    --accent-pink-glow: 0 0 20px rgba(255, 51, 102, 0.4);

    --bg-dim-overlay:  rgba(6, 2, 14, 0.75);
    --scrollbar-thumb: rgba(255, 51, 102, 0.3);
  }

  /* ═══ LIGHT THEME ═══ */
  [data-theme="light"] {
    --bg-primary:    #fef5f7;
    --bg-secondary:  #ffffff;
    --bg-glass:      rgba(254, 245, 247, 0.8);
    --bg-card:       rgba(255, 255, 255, 0.85);
    --bg-card-hover: rgba(255, 255, 255, 1);

    --text-primary:   #1a0510;
    --text-secondary: rgba(26, 5, 16, 0.75);
    --text-muted:     rgba(26, 5, 16, 0.5);
    --text-faint:     rgba(26, 5, 16, 0.22);

    --border-color:  rgba(255, 51, 102, 0.15);
    --border-hover:  rgba(255, 51, 102, 0.4);

    --accent-pink:      #e6295a;
    --accent-pink-hot:  #cc0066;
    --accent-cyan:      #0099cc;
    --accent-purple:    #8b3fbf;
    --accent-gradient:  linear-gradient(135deg, #e6295a, #cc0066);
    --accent-cyan-glow: 0 0 20px rgba(0, 153, 204, 0.3);
    --accent-pink-glow: 0 0 20px rgba(230, 41, 90, 0.3);

    --bg-dim-overlay:  rgba(254, 245, 247, 0.82);
    --scrollbar-thumb: rgba(255, 51, 102, 0.25);
  }

  /* ═══ LAYOUT VARS ═══ */
  :root {
    --header-height: 68px;
    --font-body:    'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-heading: 'Bricolage Grotesque', 'DM Sans', sans-serif;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --radius-round: 999px;
    --transition-fast:   0.2s ease;
    --transition-normal: 0.3s ease;
    --max-w: 1360px;
  }

  /* ═══ BODY ═══ */
  body {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    transition: background 0.4s ease, color 0.4s ease;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  p, li, span, div, td, th, label { color: inherit; }
  p, li { color: var(--text-secondary); }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  ::selection { background: rgba(255, 51, 102, 0.35); color: #fff; }

  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 9px; }

  /* ═══ LOADER ═══ */
  #loader {
    position: fixed; inset: 0;
    background: var(--bg-primary);
    z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 1rem;
    transition: opacity 0.5s ease;
  }

  .ld-brand {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .ld-track {
    width: 160px; height: 2px;
    background: var(--border-color);
    border-radius: 9px; overflow: hidden;
  }

  .ld-bar {
    height: 100%;
    background: var(--accent-gradient);
    border-radius: 9px;
    animation: ld-fill 0.8s ease forwards;
  }

  @keyframes ld-fill { from { width: 0; } to { width: 100%; } }

  /* ═══ ANIME BACKGROUND ═══ */
  #anime-bg {
    position: fixed; inset: 0;
    z-index: 0; overflow: hidden;
    pointer-events: none;
  }

  .abg-slide {
    position: absolute; inset: -30px;
    background-size: cover;
    background-position: center center;
    opacity: 0;
    transition: opacity 2.5s ease-in-out;
    filter: blur(6px) brightness(0.55) saturate(1.4);
    transform: scale(1.08);
  }

  .abg-slide.abg-active { opacity: 1; }

  .abg-dark {
    position: absolute; inset: 0;
    background: var(--bg-dim-overlay);
    transition: background 0.4s ease;
  }

  .abg-gradient {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 15% 5%, rgba(255, 51, 102, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 90%, rgba(0, 212, 255, 0.14) 0%, transparent 55%);
  }

  [data-theme="light"] .abg-slide {
    filter: blur(8px) brightness(1.1) saturate(0.7) contrast(0.85);
    opacity: 0.15 !important;
  }
  [data-theme="light"] .abg-slide.abg-active { opacity: 0.15 !important; }

  /* ═══ APP ═══ */
  #app {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column;
  }
  main { flex: 1; }

  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  @media (max-width: 640px) { .container { padding: 0 1rem; } }

  /* ═══ BACK TO TOP ═══ */
  #btt {
    position: fixed; bottom: 1.5rem; right: 1.5rem;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--accent-gradient);
    border: none; color: #fff;
    display: flex; align-items: center; justify-content: center;
    z-index: 1000;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s, transform 0.2s;
    cursor: pointer;
    box-shadow: var(--accent-pink-glow);
  }
  #btt:hover { transform: translateY(-3px); }

  /* ═══ LOGO STYLES (shared) ═══ */
  .logo-ani {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .logo-tube { color: var(--text-primary); }
  .logo-buzz {
    color: var(--accent-cyan);
    margin-left: 3px;
    text-shadow: 0 0 15px rgba(0, 212, 255, 0.5);
  }

  /* ═══ SECTION HEADERS ═══ */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .section-header-left { display: flex; align-items: center; gap: 0.75rem; }

  .section-accent-bar {
    width: 4px;
    height: 28px;
    background: var(--accent-gradient);
    border-radius: 3px;
    box-shadow: var(--accent-pink-glow);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .section-view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent-cyan);
    transition: gap 0.2s;
  }

  .section-view-all:hover { gap: 0.5rem; color: var(--accent-pink); }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ═══ CARDS ═══ */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .card:hover {
    border-color: var(--border-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(255, 51, 102, 0.15);
  }

  /* ═══ BADGES ═══ */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-pink   { background: rgba(255, 51, 102, 0.15); color: var(--accent-pink); }
  .badge-cyan   { background: rgba(0, 212, 255, 0.12);  color: var(--accent-cyan); }
  .badge-purple { background: rgba(168, 85, 247, 0.12); color: var(--accent-purple); }
  .badge-gold   { background: rgba(255, 215, 0, 0.1);   color: #ffd700; }

  .cat-news        { background: rgba(255, 107, 0, 0.12); color: #ff9f4a; }
  .cat-anime-recap { background: rgba(255, 51, 102, 0.12); color: var(--accent-pink); }
  .cat-manhwa      { background: rgba(0, 212, 255, 0.12); color: var(--accent-cyan); }
  .cat-streaming   { background: rgba(255, 0, 128, 0.12); color: #ff6eb4; }
  .cat-gaming      { background: rgba(0, 255, 128, 0.08); color: #00ff80; }
  .cat-manga       { background: rgba(255, 215, 0, 0.1);  color: #ffd700; }

  /* ═══ BUTTONS ═══ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius-md);
    font-size: 0.88rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: none;
    transition: all var(--transition-fast);
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: #fff;
    box-shadow: 0 4px 15px rgba(255, 51, 102, 0.35);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 51, 102, 0.5);
  }

  .btn-secondary {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    backdrop-filter: blur(10px);
  }
  .btn-secondary:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }

  .btn-cyan {
    background: rgba(0, 212, 255, 0.15);
    border: 1px solid rgba(0, 212, 255, 0.3);
    color: var(--accent-cyan);
    backdrop-filter: blur(10px);
  }
  .btn-cyan:hover {
    background: rgba(0, 212, 255, 0.25);
    border-color: rgba(0, 212, 255, 0.5);
    box-shadow: var(--accent-cyan-glow);
  }

  /* ═══ SCORE ═══ */
  .score-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    background: rgba(255, 215, 0, 0.15);
    border: 1px solid rgba(255, 215, 0, 0.3);
    color: #ffd700;
  }

  /* ═══ DIVIDER ═══ */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    margin: 2rem 0;
  }

  /* ═══ VIDEO EMBED ═══ */
  .video-embed-wrapper {
    position: relative; width: 100%;
    aspect-ratio: 16/9;
    border-radius: var(--radius-lg); overflow: hidden;
    background: #000;
    border: 1px solid var(--border-color);
    margin: 1.5rem 0;
  }
  .video-embed-wrapper iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%; border: none;
  }

  /* ═══ PROSE (article body) ═══ */
  .prose { color: var(--text-secondary); line-height: 1.8; font-size: 1rem; }
  .prose h2 {
    font-size: 1.4rem; color: var(--text-primary);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }
  .prose h3 { font-size: 1.1rem; color: var(--text-primary); margin: 1.5rem 0 0.5rem; }
  .prose p { margin-bottom: 1rem; color: var(--text-secondary); }
  .prose a { color: var(--accent-pink); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--accent-cyan); }
  .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text-secondary); }
  .prose li { margin-bottom: 0.3rem; }
  .prose blockquote {
    border-left: 3px solid var(--accent-pink);
    padding: 0.75rem 1rem;
    background: rgba(255, 51, 102, 0.06);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    margin: 1rem 0; font-style: italic;
  }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9rem; }
  .prose th {
    background: rgba(255, 51, 102, 0.08); color: var(--accent-pink);
    padding: 0.6rem 0.9rem; text-align: left;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .prose td { padding: 0.6rem 0.9rem; border-bottom: 1px solid rgba(255, 51, 102, 0.05); color: var(--text-secondary); }
  .prose tr:hover td { background: rgba(255, 51, 102, 0.03); }
  .prose hr {
    border: none; height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    margin: 2rem 0;
  }

  /* ═══ SKELETON ═══ */
  .skeleton {
    background: linear-gradient(90deg,
      rgba(255, 51, 102, 0.04) 25%,
      rgba(255, 51, 102, 0.08) 50%,
      rgba(255, 51, 102, 0.04) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: var(--radius-sm);
  }
  @keyframes shimmer { from { background-position: -200% 0; } to { background-position: 200% 0; } }

  mark.hl { background: rgba(255, 51, 102, 0.3); color: var(--text-primary); border-radius: 2px; padding: 0 2px; }

  /* ═══ TICKER ═══ */
  .ticker-wrap {
    background: rgba(255, 51, 102, 0.04);
    border-top: 1px solid rgba(255, 51, 102, 0.1);
    border-bottom: 1px solid rgba(255, 51, 102, 0.1);
    overflow: hidden;
    padding: 0.55rem 0;
    position: relative;
  }
  .ticker-wrap::before, .ticker-wrap::after {
    content: ''; position: absolute; top: 0; bottom: 0;
    width: 60px; z-index: 2; pointer-events: none;
  }
  .ticker-wrap::before { left: 0; background: linear-gradient(90deg, var(--bg-primary), transparent); }
  .ticker-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--bg-primary), transparent); }
  .ticker-label {
    position: absolute; left: 0; top: 0; bottom: 0; z-index: 3;
    background: var(--accent-gradient);
    display: flex; align-items: center;
    padding: 0 0.9rem;
    font-family: var(--font-heading);
    font-size: 0.65rem; font-weight: 800;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: #fff; white-space: nowrap;
  }
  .ticker-track {
    display: flex;
    animation: ticker-move 90s linear infinite;
    width: max-content;
    padding-left: 130px;
    will-change: transform;
  }
  .ticker-track:hover { animation-play-state: paused; }
  .ticker-item {
    display: inline-flex; align-items: center; gap: 0.35rem;
    padding: 0 1.2rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    white-space: nowrap;
    transition: color 0.2s;
  }
