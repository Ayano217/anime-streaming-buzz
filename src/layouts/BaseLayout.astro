---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = 'AniTube Buzz — Anime News, Reviews & Streaming Guide',
  description = 'Your premium source for anime news, episode recaps, manga updates and streaming guides.',
  image = '/og-default.jpg',
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://anime-streaming-buzz.pages.dev');
const fullTitle = title.includes('AniTube') ? title : `${title} | AniTube Buzz`;
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="AniTube Buzz" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Premium Anime Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Prevent theme flash -->
  <script is:inline>
    (function(){
      var saved = localStorage.getItem('theme');
      if(saved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>

<body>

  <!-- Loader -->
  <div id="loader">
    <div class="ld-brand">
      <span class="ld-ani">Ani</span><span class="ld-tube">Tube</span><span class="ld-buzz">Buzz</span>
    </div>
    <div class="ld-track"><div class="ld-bar"></div></div>
  </div>

  <!-- Animated Background -->
  <div id="anime-bg" aria-hidden="true">
    <div class="abg-glow abg-g1"></div>
    <div class="abg-glow abg-g2"></div>
    <div class="abg-glow abg-g3"></div>
    <div class="abg-glow abg-g4"></div>
    <div class="abg-grid"></div>
  </div>

  <!-- App -->
  <div id="app">
    <slot name="header" />
    <main><slot /></main>
    <slot name="footer" />
  </div>

  <!-- Back to Top -->
  <button id="btt" aria-label="Scroll to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <script is:inline>
  (function(){
    // Loader hide
    window.addEventListener('load', function(){
      setTimeout(function(){
        var l = document.getElementById('loader');
        if(l){ l.style.opacity='0'; setTimeout(function(){ l.style.display='none'; },500); }
      },700);
    });

    // Back to top
    var btt = document.getElementById('btt');
    if(btt){
      window.addEventListener('scroll',function(){
        var show = window.scrollY > 400;
        btt.style.opacity = show ? '1' : '0';
        btt.style.pointerEvents = show ? 'auto' : 'none';
      });
      btt.addEventListener('click',function(){ window.scrollTo({top:0,behavior:'smooth'}); });
    }
  })();
  </script>

</body>
</html>

<style is:global>
  /* ══════════════════════════════════════
     RESET
     ══════════════════════════════════════ */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  /* ══════════════════════════════════════
     DARK MODE (default)
     ══════════════════════════════════════ */
  [data-theme="dark"] {
    /* Backgrounds */
    --bg-primary:    #0a0510;
    --bg-secondary:  #12081e;
    --bg-glass:      rgba(10, 5, 16, 0.75);
    --bg-card:       rgba(18, 8, 30, 0.75);
    --bg-card-hover: rgba(24, 12, 40, 0.85);

    /* Text — WHITE in dark mode */
    --text-primary:   #ffffff;
    --text-secondary: rgba(255, 255, 255, 0.72);
    --text-muted:     rgba(255, 255, 255, 0.45);
    --text-faint:     rgba(255, 255, 255, 0.2);

    /* Borders */
    --border-color:  rgba(255, 51, 102, 0.15);
    --border-hover:  rgba(255, 51, 102, 0.4);

    /* Accents — PINK/RED (from your logo color) */
    --accent-primary:   #ff3366;
    --accent-secondary: #ff0080;
    --accent-tertiary:  #00d4ff;
    --accent-gradient:  linear-gradient(135deg, #ff3366, #ff0080);

    /* Glows */
    --glow-pink: 0 0 20px rgba(255, 51, 102, 0.3);
    --glow-cyan: 0 0 20px rgba(0, 212, 255, 0.3);

    /* Background glows */
    --glow-1-color: rgba(255, 51, 102, 0.1);
    --glow-2-color: rgba(255, 0, 128, 0.08);
    --glow-3-color: rgba(0, 212, 255, 0.06);
    --glow-4-color: rgba(139, 0, 255, 0.05);

    /* Grid + ticker */
    --grid-color:      rgba(255, 51, 102, 0.03);
    --ticker-bg:       rgba(255, 51, 102, 0.04);
    --ticker-border:   rgba(255, 51, 102, 0.1);
    --ticker-label-bg: rgba(255, 51, 102, 0.85);
    --ticker-fade:     #0a0510;

    /* Scrollbar */
    --scrollbar-thumb: rgba(255, 51, 102, 0.3);
  }

  /* ══════════════════════════════════════
     LIGHT MODE
     ══════════════════════════════════════ */
  [data-theme="light"] {
    /* Backgrounds */
    --bg-primary:    #fef5f7;
    --bg-secondary:  #ffffff;
    --bg-glass:      rgba(254, 245, 247, 0.85);
    --bg-card:       rgba(255, 255, 255, 0.9);
    --bg-card-hover: rgba(255, 255, 255, 1);

    /* Text — BLACK in light mode */
    --text-primary:   #1a0510;
    --text-secondary: rgba(26, 5, 16, 0.78);
    --text-muted:     rgba(26, 5, 16, 0.5);
    --text-faint:     rgba(26, 5, 16, 0.22);

    /* Borders */
    --border-color:  rgba(255, 51, 102, 0.15);
    --border-hover:  rgba(255, 51, 102, 0.4);

    /* Accents — same pink/red */
    --accent-primary:   #e6295a;
    --accent-secondary: #cc0066;
    --accent-tertiary:  #0099cc;
    --accent-gradient:  linear-gradient(135deg, #e6295a, #cc0066);

    /* Glows */
    --glow-pink: 0 0 20px rgba(255, 51, 102, 0.2);
    --glow-cyan: 0 0 20px rgba(0, 153, 204, 0.2);

    /* Background glows (lighter) */
    --glow-1-color: rgba(255, 51, 102, 0.06);
    --glow-2-color: rgba(255, 0, 128, 0.04);
    --glow-3-color: rgba(0, 153, 204, 0.04);
    --glow-4-color: rgba(139, 0, 255, 0.03);

    /* Grid + ticker */
    --grid-color:      rgba(255, 51, 102, 0.03);
    --ticker-bg:       rgba(255, 51, 102, 0.03);
    --ticker-border:   rgba(255, 51, 102, 0.08);
    --ticker-label-bg: rgba(230, 41, 90, 0.85);
    --ticker-fade:     #fef5f7;

    /* Scrollbar */
    --scrollbar-thumb: rgba(255, 51, 102, 0.25);
  }

  /* ══════════════════════════════════════
     LAYOUT VARS (theme-independent)
     ══════════════════════════════════════ */
  :root {
    --header-height: 64px;
    --font-body:    'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-heading: 'Bricolage Grotesque', 'DM Sans', sans-serif;

    --radius-sm:    8px;
    --radius-md:    12px;
    --radius-lg:    16px;
    --radius-round: 999px;

    --transition-fast:   0.2s ease;
    --transition-normal: 0.3s ease;
    --transition-slow:   0.5s ease;
  }

  /* ══════════════════════════════════════
     BODY + FONTS
     ══════════════════════════════════════ */
  body {
    font-family: var(--font-body);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.65;
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    transition: background 0.4s ease, color 0.4s ease;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  p, span, div, li, td, th, a, button, input, textarea, label {
    color: inherit;
  }

  /* Force text color inheritance for common elements */
  p, li { color: var(--text-secondary); }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
  ::selection { background: rgba(255, 51, 102, 0.35); color: #fff; }

  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--scrollbar-thumb); border-radius: 9px; }

  /* ══════════════════════════════════════
     PAGE LOADER
     ══════════════════════════════════════ */
  #loader {
    position: fixed; inset: 0;
    background: var(--bg-primary);
    z-index: 99999;
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 1rem;
    transition: opacity 0.5s ease;
  }

  .ld-brand {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .ld-ani {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ld-tube { color: var(--text-primary); }

  .ld-buzz {
    color: var(--accent-tertiary);
    margin-left: 3px;
  }

  .ld-track {
    width: 140px; height: 2px;
    background: var(--border-color);
    border-radius: 9px; overflow: hidden;
  }

  .ld-bar {
    height: 100%;
    background: var(--accent-gradient);
    border-radius: 9px;
    animation: ld-fill 0.8s ease forwards;
  }

  @keyframes ld-fill { from { width: 0; } to { width: 100%; } }

  /* ══════════════════════════════════════
     ANIMATED BACKGROUND
     ══════════════════════════════════════ */
  #anime-bg {
    position: fixed; inset: 0;
    z-index: 0; overflow: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .abg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
  }

  .abg-g1 {
    width: 45vw; height: 45vw;
    max-width: 600px; max-height: 600px;
    background: var(--glow-1-color);
    top: -10%; left: -5%;
    animation: glow-move-1 18s ease-in-out infinite;
  }

  .abg-g2 {
    width: 35vw; height: 35vw;
    max-width: 450px; max-height: 450px;
    background: var(--glow-2-color);
    top: 35%; right: -8%;
    animation: glow-move-2 22s ease-in-out infinite;
  }

  .abg-g3 {
    width: 40vw; height: 40vw;
    max-width: 500px; max-height: 500px;
    background: var(--glow-3-color);
    bottom: -8%; left: 25%;
    animation: glow-move-3 20s ease-in-out infinite;
  }

  .abg-g4 {
    width: 25vw; height: 25vw;
    max-width: 350px; max-height: 350px;
    background: var(--glow-4-color);
    top: 55%; left: 60%;
    animation: glow-move-1 24s ease-in-out infinite reverse;
  }

  .abg-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(var(--grid-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.5;
  }

  @keyframes glow-move-1 {
    0%, 100% { transform: translate(0, 0); }
    33%      { transform: translate(4vw, 3vw); }
    66%      { transform: translate(-3vw, 4vw); }
  }

  @keyframes glow-move-2 {
    0%, 100% { transform: translate(0, 0); }
    33%      { transform: translate(-3vw, -2vw); }
    66%      { transform: translate(2vw, -3vw); }
  }

  @keyframes glow-move-3 {
    0%, 100% { transform: translate(0, 0); }
    33%      { transform: translate(3vw, -3vw); }
    66%      { transform: translate(-4vw, 2vw); }
  }

  /* ══════════════════════════════════════
     APP WRAPPER
     ══════════════════════════════════════ */
  #app {
    position: relative; z-index: 1;
    min-height: 100vh;
    display: flex; flex-direction: column;
  }

  main { flex: 1; }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (max-width: 640px) { .container { padding: 0 1rem; } }

  /* ══════════════════════════════════════
     BACK TO TOP
     ══════════════════════════════════════ */
  #btt {
    position: fixed; bottom: 1.5rem; right: 1.5rem;
    width: 42px; height: 42px;
    border-radius: 50%;
    background: var(--accent-gradient);
    border: none; color: #fff;
    display: flex; align-items: center; justify-content: center;
    z-index: 1000;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s, transform 0.2s;
    cursor: pointer;
    box-shadow: var(--glow-pink);
  }

  #btt:hover { transform: translateY(-3px); }

  /* ══════════════════════════════════════
     SECTION HELPERS
     ══════════════════════════════════════ */
  .section-label {
    display: inline-flex; align-items: center; gap: 0.3rem;
    background: rgba(255, 51, 102, 0.08);
    border: 1px solid rgba(255, 51, 102, 0.2);
    color: var(--accent-primary);
    padding: 0.22rem 0.7rem;
    border-radius: 999px;
    font-size: 0.65rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    font-weight: 700;
    margin-bottom: 0.15rem;
    color: var(--text-primary);
  }

  .section-sub {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1.3rem;
  }

  .gradient-text {
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ══════════════════════════════════════
     TICKER
     ══════════════════════════════════════ */
  .ticker-wrap {
    background: var(--ticker-bg);
    border-top: 1px solid var(--ticker-border);
    border-bottom: 1px solid var(--ticker-border);
    overflow: hidden;
    padding: 0.5rem 0;
    position: relative;
  }

  .ticker-wrap::before, .ticker-wrap::after {
    content: ''; position: absolute; top: 0; bottom: 0;
    width: 50px; z-index: 2; pointer-events: none;
  }

  .ticker-wrap::before { left: 0; background: linear-gradient(90deg, var(--ticker-fade), transparent); }
  .ticker-wrap::after  { right: 0; background: linear-gradient(-90deg, var(--ticker-fade), transparent); }

  .ticker-label {
    position: absolute; left: 0; top: 0; bottom: 0; z-index: 3;
    background: var(--ticker-label-bg);
    display: flex; align-items: center;
    padding: 0 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.62rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #fff; white-space: nowrap;
  }

  .ticker-track {
    display: flex;
    animation: ticker-move 90s linear infinite;
    width: max-content;
    padding-left: 110px;
    will-change: transform;
  }

  .ticker-track:hover { animation-play-state: paused; }

  .ticker-item {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0 1.1rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
    white-space: nowrap; text-decoration: none;
    transition: color 0.2s;
  }

  .ticker-item:hover { color: var(--accent-primary); }

  .ticker-sep {
    color: var(--text-faint);
    padding: 0 0.4rem; font-size: 0.4rem;
  }

  @keyframes ticker-move {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* ══════════════════════════════════════
     CARDS
     ══════════════════════════════════════ */
  .card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md); overflow: hidden;
    transition: all var(--transition-normal);
    backdrop-filter: blur(8px);
  }

  .card:hover {
    border-color: var(--border-hover);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(255, 51, 102, 0.1);
  }

  /* ══════════════════════════════════════
     BADGES
     ══════════════════════════════════════ */
  .badge {
    display: inline-flex; align-items: center;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    font-size: 0.6rem; font-weight: 700;
    letter-spacing: 0.04em; text-transform: uppercase;
  }

  .badge-pink   { background: rgba(255, 51, 102, 0.15); color: var(--accent-primary); }
  .badge-purple { background: rgba(139, 0, 255, 0.15); color: #c084fc; }
  .badge-cyan   { background: rgba(0, 212, 255, 0.1);  color: var(--accent-tertiary); }
  .badge-gold   { background: rgba(255, 215, 0, 0.1);  color: #ffd700; }

  .cat-news        { background: rgba(255, 107, 0, 0.12); color: #ff9f4a; }
  .cat-anime-recap { background: rgba(255, 51, 102, 0.12); color: var(--accent-primary); }
  .cat-manhwa      { background: rgba(0, 212, 255, 0.1);  color: var(--accent-tertiary); }
  .cat-streaming   { background: rgba(255, 0, 128, 0.1);  color: #ff6eb4; }
  .cat-gaming      { background: rgba(0, 255, 128, 0.08); color: #00ff80; }
  .cat-manga       { background: rgba(255, 215, 0, 0.1);  color: #ffd700; }

  /* ══════════════════════════════════════
     BUTTONS
     ══════════════════════════════════════ */
  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 1.4rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem; font-weight: 600;
    font-family: inherit; cursor: pointer;
    border: none; transition: all var(--transition-fast);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent-gradient);
    color: #fff;
    box-shadow: 0 4px 12px rgba(255, 51, 102, 0.25);
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255, 51, 102, 0.4);
  }

  .btn-secondary {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
  }
  .btn-secondary:hover {
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
    color: var(--text-primary);
  }

  /* ══════════════════════════════════════
     MISC
     ══════════════════════════════════════ */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    margin: 1.5rem 0;
  }

  .score-badge {
    display: inline-flex; align-items: center; gap: 0.2rem;
    padding: 0.15rem 0.45rem; border-radius: 999px;
    font-size: 0.7rem; font-weight: 700;
    background: rgba(255, 215, 0, 0.12); color: #ffd700;
  }

  .video-embed-wrapper {
    position: relative; width: 100%;
    aspect-ratio: 16/9;
    border-radius: var(--radius-md); overflow: hidden;
    background: #000;
    border: 1px solid var(--border-color);
    margin: 1.3rem 0;
  }

  .video-embed-wrapper iframe {
    position: absolute; inset: 0;
    width: 100%; height: 100%; border: none;
  }

  /* Prose (article) */
  .prose { color: var(--text-secondary); line-height: 1.8; font-size: 0.95rem; }
  .prose h2 {
    font-size: 1.3rem; color: var(--text-primary);
    margin: 1.8rem 0 0.6rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border-color);
  }
  .prose h3 { font-size: 1.05rem; color: var(--text-primary); margin: 1.3rem 0 0.4rem; }
  .prose p { margin-bottom: 0.85rem; color: var(--text-secondary); }
  .prose a { color: var(--accent-primary); text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: var(--accent-secondary); }
  .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 0.85rem; color: var(--text-secondary); }
  .prose li { margin-bottom: 0.2rem; }
  .prose blockquote {
    border-left: 3px solid var(--accent-primary);
    padding: 0.6rem 0.9rem;
    background: rgba(255, 51, 102, 0.05);
    border-radius: 0 8px 8px 0;
    margin: 0.8rem 0; font-style: italic;
  }
  .prose table { width: 100%; border-collapse: collapse; margin: 1.2rem 0; font-size: 0.85rem; }
  .prose th {
    background: rgba(255, 51, 102, 0.08); color: var(--accent-primary);
    padding: 0.5rem 0.7rem; text-align: left;
    border-bottom: 1px solid var(--border-color);
    font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .prose td { padding: 0.5rem 0.7rem; border-bottom: 1px solid rgba(255, 51, 102, 0.05); color: var(--text-secondary); }
  .prose tr:hover td { background: rgba(255, 51, 102, 0.03); }
  .prose hr {
    border: none; height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-color), transparent);
    margin: 1.5rem 0;
  }

