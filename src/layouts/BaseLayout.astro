---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
}

const {
  title = 'AniTube Buzz — Anime News, Reviews & Streaming Guide',
  description = 'Your premium source for anime news, episode recaps, manga updates, streaming guides and gaming content. Updated daily for US anime fans.',
  image = '/og-default.jpg',
  type = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://anime-streaming-buzz.pages.dev');
const fullTitle = title.includes('AniTube') ? title : `${title} | AniTube Buzz`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:title"       content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={image} />
  <meta property="og:site_name"   content="AniTube Buzz" />
  <meta property="og:locale"      content="en_US" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={image} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Premium Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Schema.org -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AniTube Buzz",
    "url": "https://anime-streaming-buzz.pages.dev",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://anime-streaming-buzz.pages.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>

<body>
  <!-- Page Loader -->
  <div id="page-loader" aria-hidden="true">
    <div class="loader-brand">ANITUBE BUZZ</div>
    <div class="loader-bar-track">
      <div class="loader-bar-fill"></div>
    </div>
    <div class="loader-sub">Loading your anime experience</div>
  </div>

  <!-- Anime Background System -->
  <div id="anime-bg" aria-hidden="true">
    <div class="anime-bg-image" id="bg-img-1"></div>
    <div class="anime-bg-image" id="bg-img-2"></div>
    <div class="anime-bg-overlay"></div>
    <div class="anime-bg-gradient"></div>
    <canvas id="particle-canvas"></canvas>
  </div>

  <!-- Custom Cursor (desktop only) -->
  <div id="cursor-dot" aria-hidden="true"></div>
  <div id="cursor-ring" aria-hidden="true"></div>

  <!-- Click ripple -->
  <div id="ripple-container" class="ripple-container" aria-hidden="true"></div>

  <!-- App -->
  <div id="app-wrapper">
    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />
  </div>

  <!-- Back to top -->
  <button id="back-to-top" aria-label="Back to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <!-- Toast -->
  <div id="toast-container" aria-live="polite"></div>

  <script is:inline>
  (function () {
    'use strict';

    var isMobile = window.innerWidth <= 768;

    // ── Page Loader ──────────────────────────────────────
    window.addEventListener('load', function () {
      setTimeout(function () {
        var l = document.getElementById('page-loader');
        if (l) l.classList.add('hidden');
      }, 900);
    });

    // ── Anime Background Image Rotation ──────────────────
    // High quality anime scene URLs from MAL CDN (official key visuals)
    var bgImages = [
      'https://cdn.myanimelist.net/images/anime/1015/138006l.jpg',
      'https://cdn.myanimelist.net/images/anime/1286/99889l.jpg',
      'https://cdn.myanimelist.net/images/anime/1337/99013l.jpg',
      'https://cdn.myanimelist.net/images/anime/1170/124312l.jpg',
      'https://cdn.myanimelist.net/images/anime/1208/94745l.jpg',
      'https://cdn.myanimelist.net/images/anime/1764/126627l.jpg',
      'https://cdn.myanimelist.net/images/anime/1935/127974l.jpg',
      'https://cdn.myanimelist.net/images/anime/1015/138006l.jpg',
      'https://cdn.myanimelist.net/images/anime/1792/134026l.jpg',
      'https://cdn.myanimelist.net/images/anime/1004/131809l.jpg',
    ];

    var bgEl1 = document.getElementById('bg-img-1');
    var bgEl2 = document.getElementById('bg-img-2');
    var currentBg = 0;
    var activeEl = bgEl1;

    function preloadImage(url, cb) {
      var img = new Image();
      img.onload = function () { cb(url); };
      img.onerror = function () { cb(null); };
      img.src = url;
    }

    function setInitialBg() {
      if (!bgEl1) return;
      var idx = Math.floor(Math.random() * bgImages.length);
      currentBg = idx;
      bgEl1.style.backgroundImage = 'url(' + bgImages[idx] + ')';
      bgEl1.style.opacity = '1';
    }

    function rotateBg() {
      currentBg = (currentBg + 1) % bgImages.length;
      var nextUrl = bgImages[currentBg];
      var inactiveEl = activeEl === bgEl1 ? bgEl2 : bgEl1;

      preloadImage(nextUrl, function (url) {
        if (!url) return;
        inactiveEl.style.backgroundImage = 'url(' + url + ')';
        inactiveEl.style.opacity = '1';
        activeEl.style.opacity = '0';
        activeEl = inactiveEl;
      });
    }

    setInitialBg();
    setInterval(rotateBg, 12000); // Change every 12 seconds

    // ── Particle System ──────────────────────────────────
    var canvas = document.getElementById('particle-canvas');
    var ctx = canvas ? canvas.getContext('2d') : null;
    var pts = [];

    function resizeCanvas() {
      if (!canvas) return;
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }

    function initPts(n) {
      pts = [];
      for (var i = 0; i < n; i++) {
        pts.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          vx: (Math.random() - 0.5) * 0.2,
          vy: (Math.random() - 0.5) * 0.2,
          r: Math.random() * 1.2 + 0.3,
          a: Math.random() * 0.3 + 0.05,
        });
      }
    }

    function drawPts() {
      if (!ctx) return;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      for (var i = 0; i < pts.length; i++) {
        var p = pts[i];
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(192, 132, 252, ' + p.a + ')';
        ctx.fill();
      }
      requestAnimationFrame(drawPts);
    }

    if (canvas) {
      resizeCanvas();
      initPts(isMobile ? 20 : 40);
      drawPts();
      window.addEventListener('resize', function () {
        resizeCanvas();
        initPts(isMobile ? 20 : 40);
      });
    }

    // ── Custom Cursor (desktop) ──────────────────────────
    if (!isMobile) {
      var dot = document.getElementById('cursor-dot');
      var ring = document.getElementById('cursor-ring');
      var mx = 0, my = 0, rx = 0, ry = 0;

      document.addEventListener('mousemove', function (e) {
        mx = e.clientX;
        my = e.clientY;
        if (dot) dot.style.transform = 'translate(' + (mx - 4) + 'px,' + (my - 4) + 'px)';
      });

      function animRing() {
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        if (ring) ring.style.transform = 'translate(' + (rx - 16) + 'px,' + (ry - 16) + 'px)';
        requestAnimationFrame(animRing);
      }
      animRing();

      document.addEventListener('mousedown', function () {
        document.body.classList.add('cursor-click');
      });
      document.addEventListener('mouseup', function () {
        document.body.classList.remove('cursor-click');
      });

      // Hover effect
      var hoverSel = 'a, button, [role="button"], input, textarea, .card, .fb-card, .news-card';
      document.addEventListener('mouseover', function (e) {
        if (e.target.closest(hoverSel)) document.body.classList.add('cursor-hover');
      });
      document.addEventListener('mouseout', function (e) {
        if (e.target.closest(hoverSel)) document.body.classList.remove('cursor-hover');
      });
    }

    // ── Click Ripple ─────────────────────────────────────
    document.addEventListener('click', function (e) {
      var c = document.getElementById('ripple-container');
      if (!c) return;
      var r = document.createElement('div');
      r.className = 'click-ripple';
      r.style.left = e.clientX + 'px';
      r.style.top = e.clientY + 'px';
      c.appendChild(r);
      setTimeout(function () { r.remove(); }, 700);
    });

    // ── Back to Top ──────────────────────────────────────
    var btt = document.getElementById('back-to-top');
    if (btt) {
      window.addEventListener('scroll', function () {
        btt.classList.toggle('visible', window.scrollY > 500);
      });
      btt.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // ── Scroll Reveal ────────────────────────────────────
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (en) {
          if (en.isIntersecting) {
            en.target.classList.add('visible');
            obs.unobserve(en.target);
          }
        });
      }, { threshold: 0.08 });

      document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
    }

  })();
  </script>
</body>
</html>

<style is:global>
  /* ── Fonts ── */
  body {
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #04020f;
    color: #fff;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Space Grotesk', 'Outfit', sans-serif;
    font-weight: 700;
    line-height: 1.2;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* ── Anime Background ── */
  #anime-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .anime-bg-image {
    position: absolute;
    inset: -20px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 3s ease-in-out;
    filter: blur(12px) brightness(0.25) saturate(1.4);
    transform: scale(1.1);
  }

  .anime-bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(4, 2, 15, 0.65);
  }

  .anime-bg-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 0%, rgba(139,0,255,0.1) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 100%, rgba(0,212,255,0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, rgba(255,0,128,0.04) 0%, transparent 60%);
  }

  #particle-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ── App Wrapper ── */
  #app-wrapper {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  /* ── Page Loader ── */
  #page-loader {
    position: fixed;
    inset: 0;
    background: #04020f;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1.2rem;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  #page-loader.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .loader-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    background: linear-gradient(135deg, #8b00ff, #00d4ff, #ff0080);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 2s ease infinite;
  }

  .loader-bar-track {
    width: 180px;
    height: 3px;
    background: rgba(255,255,255,0.08);
    border-radius: 999px;
    overflow: hidden;
  }

  .loader-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #8b00ff, #00d4ff);
    border-radius: 999px;
    animation: loader-fill 1s ease forwards;
  }

  @keyframes loader-fill {
    0%   { width: 0; }
    60%  { width: 75%; }
    100% { width: 100%; }
  }

  .loader-sub {
    font-size: 0.7rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  @keyframes gradient-shift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* ── Cursor ── */
  @media (min-width: 769px) {
    body { cursor: none; }
    a, button, input, textarea, select { cursor: none; }
  }

  #cursor-dot {
    width: 8px;
    height: 8px;
    background: #8b00ff;
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99998;
    box-shadow: 0 0 8px #8b00ff, 0 0 16px rgba(139,0,255,0.5);
    transition: transform 0.05s linear;
  }

  #cursor-ring {
    width: 32px;
    height: 32px;
    border: 1.5px solid rgba(139,0,255,0.5);
    border-radius: 50%;
    position: fixed;
    top: 0; left: 0;
    pointer-events: none;
    z-index: 99997;
    transition: width 0.2s ease, height 0.2s ease, border-color 0.2s ease;
  }

  body.cursor-hover #cursor-dot {
    transform: scale(2.5) !important;
    background: #00d4ff;
    box-shadow: 0 0 12px #00d4ff;
  }

  body.cursor-hover #cursor-ring {
    width: 48px;
    height: 48px;
    border-color: rgba(0,212,255,0.5);
  }

  body.cursor-click #cursor-dot {
    transform: scale(0.5) !important;
  }

  @media (max-width: 768px) {
    #cursor-dot, #cursor-ring { display: none !important; }
  }

  /* ── Click Ripple ── */
  .ripple-container {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 99995;
    overflow: hidden;
  }

  .click-ripple {
    position: absolute;
    width: 20px;
    height: 20px;
    margin: -10px 0 0 -10px;
    border: 2px solid rgba(139,0,255,0.6);
    border-radius: 50%;
    animation: ripple-out 0.6s ease-out forwards;
    pointer-events: none;
  }

  @keyframes ripple-out {
    0%   { transform: scale(0); opacity: 1; }
    100% { transform: scale(6); opacity: 0; }
  }

  /* ── Back to Top ── */
  #back-to-top {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, #8b00ff, #5500cc);
    border: 1px solid rgba(139,0,255,0.5);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(139,0,255,0.4);
  }

  #back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #back-to-top:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(139,0,255,0.5);
  }

  /* ── Toast ── */
  #toast-container {
    position: fixed;
    bottom: 2rem;
    right: 5rem;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    pointer-events: none;
  }

  .toast {
    background: rgba(13, 6, 32, 0.95);
    border: 1px solid rgba(139,0,255,0.3);
    border-radius: 10px;
    padding: 0.65rem 1rem;
    color: rgba(255,255,255,0.8);
    font-size: 0.8rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.5);
    animation: toast-slide 0.3s ease forwards;
    pointer-events: auto;
    max-width: 280px;
  }

  @keyframes toast-slide {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Links ── */
  a { color: inherit; text-decoration: none; }

  img { max-width: 100%; height: auto; display: block; }

  /* ── Selection ── */
  ::selection {
    background: rgba(139,0,255,0.35);
    color: #fff;
  }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: rgba(255,255,255,0.02); }
  ::-webkit-scrollbar-thumb { background: rgba(139,0,255,0.3); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(139,0,255,0.5); }

  /* ── Accessibility ── */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
    .anime-bg-image { transition-duration: 0.01ms !important; }
  }
</style>
