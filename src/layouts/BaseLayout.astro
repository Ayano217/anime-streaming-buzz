---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
}

const {
  title = 'AniTube Buzz — Anime News, Reviews & Streaming Guide',
  description = 'Your premium source for anime news, episode recaps, manga updates, streaming guides and gaming content.',
  image = '/og-default.jpg',
  type = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://anime-streaming-buzz.pages.dev');
const fullTitle = title.includes('AniTube') ? title : `${title} | AniTube Buzz`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:site_name" content="AniTube Buzz" />
  <meta property="og:locale" content="en_US" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "AniTube Buzz",
    "url": "https://anime-streaming-buzz.pages.dev",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://anime-streaming-buzz.pages.dev/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>

<body>

  <!-- Simple Page Loader -->
  <div id="loader">
    <div class="loader-inner">
      <div class="loader-text">ANITUBE BUZZ</div>
      <div class="loader-bar"><div class="loader-fill"></div></div>
    </div>
  </div>

  <!-- Animated Background (pure CSS, no JS, no lag) -->
  <div class="bg-animated" aria-hidden="true">
    <div class="bg-glow bg-glow-1"></div>
    <div class="bg-glow bg-glow-2"></div>
    <div class="bg-glow bg-glow-3"></div>
    <div class="bg-noise"></div>
  </div>

  <!-- App -->
  <div id="app">
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </div>

  <!-- Back to Top -->
  <button id="btt" aria-label="Back to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M18 15l-6-6-6 6"/></svg>
  </button>

  <script is:inline>
  (function(){
    // Loader
    window.addEventListener('load', function(){
      setTimeout(function(){
        var l = document.getElementById('loader');
        if(l) { l.style.opacity='0'; setTimeout(function(){ l.style.display='none'; }, 500); }
      }, 600);
    });

    // Back to top
    var b = document.getElementById('btt');
    if(b){
      window.addEventListener('scroll', function(){
        b.style.opacity = window.scrollY > 400 ? '1' : '0';
        b.style.pointerEvents = window.scrollY > 400 ? 'auto' : 'none';
      });
      b.addEventListener('click', function(){
        window.scrollTo({top:0, behavior:'smooth'});
      });
    }
  })();
  </script>

</body>
</html>

<style is:global>
  /* ── RESET ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  /* ── FONTS ── */
  body {
    font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #06020e;
    color: #fff;
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Space Grotesk', 'Outfit', sans-serif;
    font-weight: 700;
    line-height: 1.2;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }

  ::selection { background: rgba(139,0,255,0.35); color: #fff; }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 5px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(139,0,255,0.3); border-radius: 9px; }

  /* ── PAGE LOADER ── */
  #loader {
    position: fixed;
    inset: 0;
    background: #06020e;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease;
  }

  .loader-inner { text-align: center; }

  .loader-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: #c084fc;
    margin-bottom: 1rem;
  }

  .loader-bar {
    width: 160px;
    height: 3px;
    background: rgba(255,255,255,0.08);
    border-radius: 9px;
    overflow: hidden;
  }

  .loader-fill {
    height: 100%;
    background: linear-gradient(90deg, #8b00ff, #00d4ff);
    border-radius: 9px;
    animation: load-fill 0.8s ease forwards;
  }

  @keyframes load-fill {
    from { width: 0; }
    to { width: 100%; }
  }

  /* ── ANIMATED BACKGROUND (Pure CSS — ZERO lag) ── */
  .bg-animated {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
  }

  .bg-glow-1 {
    width: 50vw;
    height: 50vw;
    max-width: 700px;
    max-height: 700px;
    background: rgba(139, 0, 255, 0.12);
    top: -15%;
    left: -10%;
    animation: glow-drift-1 20s ease-in-out infinite;
  }

  .bg-glow-2 {
    width: 40vw;
    height: 40vw;
    max-width: 500px;
    max-height: 500px;
    background: rgba(0, 212, 255, 0.08);
    top: 40%;
    right: -10%;
    animation: glow-drift-2 25s ease-in-out infinite;
  }

  .bg-glow-3 {
    width: 35vw;
    height: 35vw;
    max-width: 450px;
    max-height: 450px;
    background: rgba(255, 0, 128, 0.06);
    bottom: -10%;
    left: 30%;
    animation: glow-drift-3 22s ease-in-out infinite;
  }

  /* Subtle noise texture */
  .bg-noise {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px 200px;
  }

  @keyframes glow-drift-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(5vw, 3vw) scale(1.1); }
    66%      { transform: translate(-3vw, 5vw) scale(0.95); }
  }

  @keyframes glow-drift-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(-4vw, -3vw) scale(1.05); }
    66%      { transform: translate(3vw, -4vw) scale(0.9); }
  }

  @keyframes glow-drift-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33%      { transform: translate(3vw, -4vw) scale(1.08); }
    66%      { transform: translate(-5vw, 2vw) scale(0.92); }
  }

  /* ── APP WRAPPER ── */
  #app {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (max-width: 640px) {
    .container { padding: 0 1rem; }
  }

  /* ── BACK TO TOP ── */
  #btt {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(139,0,255,0.8);
    border: 1px solid rgba(139,0,255,0.6);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.2s ease;
    cursor: pointer;
    box-shadow: 0 4px 15px rgba(139,0,255,0.4);
  }

  #btt:hover { transform: translateY(-3px); }

  /* ══════════════════════════════════════════════════════
     SECTION STYLES (shared across components)
     ══════════════════════════════════════════════════════ */

  /* Section labels */
  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: rgba(139,0,255,0.1);
    border: 1px solid rgba(139,0,255,0.25);
    color: #c084fc;
    padding: 0.22rem 0.7rem;
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.3rem, 2.8vw, 1.9rem);
    font-weight: 800;
    margin-bottom: 0.2rem;
  }

  .section-sub {
    color: rgba(255,255,255,0.4);
    font-size: 0.82rem;
    margin-bottom: 1.3rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #fff, #c084fc, #00d4ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── TRENDING TICKER (VERY SLOW — NO SHAKE) ── */
  .ticker-wrap {
    background: rgba(139,0,255,0.05);
    border-top: 1px solid rgba(139,0,255,0.12);
    border-bottom: 1px solid rgba(139,0,255,0.12);
    overflow: hidden;
    padding: 0.5rem 0;
    position: relative;
  }

  .ticker-wrap::before,
  .ticker-wrap::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 50px;
    z-index: 2;
    pointer-events: none;
  }

  .ticker-wrap::before {
    left: 0;
    background: linear-gradient(90deg, #06020e, transparent);
  }

  .ticker-wrap::after {
    right: 0;
    background: linear-gradient(-90deg, #06020e, transparent);
  }

  .ticker-label {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    z-index: 3;
    background: rgba(139,0,255,0.9);
    display: flex;
    align-items: center;
    padding: 0 0.7rem;
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    white-space: nowrap;
    border-radius: 0 4px 4px 0;
  }

  .ticker-track {
    display: flex;
    /* 80 SECONDS — very slow and smooth */
    animation: ticker-move 80s linear infinite;
    width: max-content;
    padding-left: 110px;
    /* Force GPU acceleration for smoothness */
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  .ticker-track:hover {
    animation-play-state: paused;
  }

  .ticker-item {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0 1.2rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.65);
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.2s;
  }

  .ticker-item:hover { color: #fff; }

  .ticker-sep {
    color: rgba(139,0,255,0.4);
    font-size: 0.5rem;
    padding: 0 0.5rem;
  }

  @keyframes ticker-move {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ── CARDS ── */
  .card {
    background: rgba(10, 6, 24, 0.7);
    border: 1px solid rgba(139,0,255,0.15);
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    backdrop-filter: blur(4px);
  }

  .card:hover {
    border-color: rgba(139,0,255,0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(139,0,255,0.12);
  }

  /* ── BADGES ── */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-purple { background: rgba(139,0,255,0.15); color: #c084fc; }
  .badge-cyan   { background: rgba(0,212,255,0.1);  color: #00d4ff; }
  .badge-pink   { background: rgba(255,0,128,0.1);  color: #ff6eb4; }
  .badge-gold   { background: rgba(255,215,0,0.1);  color: #ffd700; }

  /* Category badges */
  .cat-news        { background: rgba(255,107,0,0.12); color: #ff9f4a; }
  .cat-anime-recap { background: rgba(139,0,255,0.12); color: #c084fc; }
  .cat-manhwa      { background: rgba(0,212,255,0.1);  color: #00d4ff; }
  .cat-streaming   { background: rgba(255,0,128,0.1);  color: #ff6eb4; }
  .cat-gaming      { background: rgba(0,255,128,0.08); color: #00ff80; }
  .cat-manga       { background: rgba(255,215,0,0.1);  color: #ffd700; }

  /* ── BUTTONS ── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.55rem 1.3rem;
    border-radius: 10px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-primary {
    background: linear-gradient(135deg, #8b00ff, #5500cc);
    color: #fff;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(139,0,255,0.35);
  }

  .btn-secondary {
    background: rgba(139,0,255,0.1);
    border: 1px solid rgba(139,0,255,0.2);
    color: rgba(255,255,255,0.7);
  }

  .btn-secondary:hover {
    background: rgba(139,0,255,0.2);
    color: #fff;
  }

  /* ── SCORE ── */
  .score-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.18rem 0.45rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(255,215,0,0.12);
    color: #ffd700;
  }

  /* ── DIVIDER ── */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139,0,255,0.2), transparent);
    margin: 1.5rem 0;
  }

  /* ── VIDEO EMBED ── */
  .video-embed-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(139,0,255,0.15);
    margin: 1.5rem 0;
  }

  .video-embed-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── PROSE (article content) ── */
  .prose {
    color: rgba(255,255,255,0.7);
    line-height: 1.8;
    font-size: 0.95rem;
  }

  .prose h2 {
    font-size: 1.3rem;
    color: #fff;
    margin: 1.8rem 0 0.6rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(139,0,255,0.15);
  }

  .prose h3 {
    font-size: 1.05rem;
    color: #fff;
    margin: 1.3rem 0 0.4rem;
  }

  .prose p { margin-bottom: 0.9rem; }

  .prose a { color: #c084fc; text-decoration: underline; text-underline-offset: 3px; }
  .prose a:hover { color: #fff; }

  .prose ul, .prose ol { padding-left: 1.5rem; margin-bottom: 0.9rem; }
  .prose li { margin-bottom: 0.2rem; }

  .prose blockquote {
    border-left: 3px solid #8b00ff;
    padding: 0.6rem 0.9rem;
    background: rgba(139,0,255,0.05);
    border-radius: 0 8px 8px 0;
    margin: 0.8rem 0;
    font-style: italic;
  }

  .prose table { width: 100%; border-collapse: collapse; margin: 1.2rem 0; font-size: 0.82rem; }

  .prose th {
    background: rgba(139,0,255,0.08);
    color: #c084fc;
    padding: 0.5rem 0.7rem;
    text-align: left;
    border-bottom: 1px solid rgba(139,0,255,0.15);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .prose td {
    padding: 0.5rem 0.7rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }

  .prose tr:hover td { background: rgba(139,0,255,0.03); }

  .prose hr {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(139,0,255,0.2), transparent);
    margin: 1.5rem 0;
  }

  /* ── TABS ── */
  .tabs {
    display: flex;
    gap: 0.2rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 1rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }

  .tab {
    padding: 0.5rem 0.9rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: rgba(255,255,255,0.4);
    border: none;
    background: transparent;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    font-family: inherit;
    transition: color 0.2s;
    margin-bottom: -1px;
  }

  .tab:hover { color: rgba(255,255,255,0.7); }
  .tab.active { color: #c084fc; border-bottom-color: #8b00ff; }

  /* ── SKELETON ── */
  .skeleton {
    background: linear-gradient(90deg,
      rgba(255,255,255,0.03) 25%,
      rgba(255,255,255,0.06) 50%,
      rgba(255,255,255,0.03) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 8px;
  }

  @keyframes shimmer {
    from { background-position: -200% 0; }
    to   { background-position:  200% 0; }
  }

  /* ── SEARCH HIGHLIGHT ── */
  mark.hl {
    background: rgba(139,0,255,0.3);
    color: #fff;
    border-radius: 2px;
    padding: 0 2px;
  }

  /* ── ANIMATIONS ── */
  .reveal {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>
