---
export interface HeroPost {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  readTime: string;
  image: string;
  slug: string;
}

export interface Props {
  mainPost: HeroPost | null;
  sidePosts?: HeroPost[];
}

const { mainPost, sidePosts = [] } = Astro.props;

const categoryLink = (category: string) =>
  `/category/${category.toLowerCase().replace(/\s+/g, '-')}`;
---

{mainPost && (
  <section class="hero-section">
    <div class="container">
      <div class="hero-grid">
        <!-- Main Hero -->
        <a href={mainPost.slug} class="hero-main">
          <div class="hero-image-wrapper">
            <img src={mainPost.image} alt={mainPost.title} loading="eager" />
            <div class="hero-overlay"></div>
          </div>
          <div class="hero-content">
            <span class="badge badge-pink">{mainPost.category}</span>
            <h1 class="hero-title">{mainPost.title}</h1>
            <p class="hero-excerpt">{mainPost.excerpt}</p>
            <div class="hero-meta">
              <span>{mainPost.date}</span>
              <span>•</span>
              <span>{mainPost.readTime}</span>
              <span>•</span>
              <span>
                <a href={categoryLink(mainPost.category)} class="hero-cat-link">
                  Browse {mainPost.category}
                </a>
              </span>
            </div>
          </div>
        </a>

        <!-- Side Posts -->
        <div class="hero-sidebar">
          {sidePosts.map((post) => (
            <a href={post.slug} class="hero-side-card">
              <div class="side-card-image">
                <img src={post.image} alt={post.title} loading="lazy" />
              </div>
              <div class="side-card-content">
                <span class="badge badge-blue">{post.category}</span>
                <h3 class="side-card-title">{post.title}</h3>
                <p class="side-card-meta">{post.date} • {post.readTime}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .hero-section {
    padding-top: calc(var(--header-height) + 30px);
    padding-bottom: 20px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    min-height: 450px;
  }

  .hero-main {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: block;
    text-decoration: none;
    transition: transform var(--transition-normal);
  }

  .hero-main:hover {
    transform: scale(1.01);
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 450px;
  }

  .hero-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 75%;
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
  }

  .hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    padding: 30px;
    z-index: 2;
  }

  .hero-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #fff;
    margin: 12px 0;
    line-height: 1.3;
  }

  .hero-excerpt {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.75);
    max-width: 650px;
    margin-bottom: 12px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.55);
  }

  .hero-cat-link {
    color: rgba(255,255,255,0.75);
  }

  .hero-cat-link:hover {
    color: #fff;
  }

  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-side-card {
    flex: 1;
    display: flex;
    gap: 12px;
    padding: 12px;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    text-decoration: none;
    transition: all var(--transition-fast);
    overflow: hidden;
  }

  .hero-side-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-glow-pink);
  }

  .side-card-image {
    width: 100px;
    min-height: 80px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }

  .side-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .side-card-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    justify-content: center;
  }

  .side-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .side-card-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-image-wrapper {
      min-height: 320px;
    }

    .hero-title {
      font-size: 1.4rem;
    }

    .hero-sidebar {
      flex-direction: row;
      overflow-x: auto;
      gap: 12px;
      padding-bottom: 8px;
    }

    .hero-side-card {
      min-width: 280px;
      flex-direction: column;
    }

    .side-card-image {
      width: 100%;
      height: 120px;
    }
  }
</style>
