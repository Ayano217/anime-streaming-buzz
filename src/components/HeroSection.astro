---
export interface HeroPost {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  readTime: string;
  image: string;
  slug: string;
}

export interface Props {
  mainPost: HeroPost | null;
  sidePosts?: HeroPost[];
}

const { mainPost, sidePosts = [] } = Astro.props;
---

{mainPost && (
  <section class="hero-section">
    <div class="container">
      <div class="hero-grid">
        <a href={mainPost.slug} class="hero-main">
          <div class="hero-media">
            <img src={mainPost.image} alt={mainPost.title} loading="eager" />
            <div class="hero-overlay"></div>

            <div class="hero-content">
              <span class="badge badge-pink">{mainPost.category}</span>
              <h1 class="hero-title">{mainPost.title}</h1>
              <p class="hero-excerpt">{mainPost.excerpt}</p>
              <div class="hero-meta">
                <span>{mainPost.date}</span>
                <span>•</span>
                <span>{mainPost.readTime}</span>
              </div>
            </div>
          </div>
        </a>

        <div class="hero-sidebar">
          {sidePosts.map((post) => (
            <a href={post.slug} class="hero-side-card">
              <div class="side-card-image">
                <img src={post.image} alt={post.title} loading="lazy" />
              </div>
              <div class="side-card-content">
                <span class="badge badge-blue">{post.category}</span>
                <h3 class="side-card-title">{post.title}</h3>
                <p class="side-card-meta">{post.date} • {post.readTime}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .hero-section {
    padding-top: calc(var(--header-height) + 24px);
    padding-bottom: 28px;
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 20px;
    align-items: stretch;
  }

  .hero-main {
    display: block;
    text-decoration: none;
  }

  .hero-media {
    position: relative;
    min-height: 520px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border-color);
    background: var(--bg-card);
  }

  .hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.92) 0%, rgba(0,0,0,.55) 45%, rgba(0,0,0,.1) 100%);
  }

  .hero-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 28px;
    z-index: 2;
  }

  .hero-title {
    font-size: 1.9rem;
    font-weight: 800;
    color: #fff;
    margin: 12px 0;
    line-height: 1.25;
  }

  .hero-excerpt {
    font-size: 0.98rem;
    color: rgba(255,255,255,.78);
    max-width: 680px;
    margin-bottom: 12px;
  }

  .hero-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 0.85rem;
    color: rgba(255,255,255,.6);
  }

  .hero-sidebar {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .hero-side-card {
    display: flex;
    gap: 12px;
    padding: 12px;
    min-height: 120px;
    border-radius: var(--radius-md);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .hero-side-card:hover {
    background: var(--bg-card-hover);
    border-color: var(--accent-primary);
  }

  .side-card-image {
    width: 108px;
    min-width: 108px;
    height: 90px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .side-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .side-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
  }

  .side-card-title {
    font-size: 0.92rem;
    line-height: 1.4;
    color: var(--text-primary);
  }

  .side-card-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-media {
      min-height: 400px;
    }

    .hero-sidebar {
      display: grid;
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .hero-media {
      min-height: 340px;
    }

    .hero-content {
      padding: 20px;
    }

    .hero-title {
      font-size: 1.35rem;
    }

    .hero-excerpt {
      font-size: 0.88rem;
    }

    .hero-side-card {
      min-height: auto;
    }
  }
</style>
