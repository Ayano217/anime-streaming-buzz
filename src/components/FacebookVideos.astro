---

<section class="fb-section section">
  <div class="container">
    <h2 class="section-title">📱 Video Updates</h2>
    <div class="fb-grid" id="fbGrid">
      <div class="fb-placeholder">
        <div class="fb-placeholder-icon">📺</div>
        <p>Loading latest videos...</p>
      </div>
    </div>
  </div>
</section>

<style>
  .fb-section {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    padding: 48px 0;
  }

  .fb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
    margin-top: 8px;
  }

  .fb-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-fast);
    position: relative;
  }

  .fb-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #1877f2, #00ccff);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .fb-card:hover {
    border-color: rgba(24, 119, 242, 0.3);
    box-shadow: 0 0 20px rgba(24, 119, 242, 0.15);
    transform: translateY(-2px);
  }

  .fb-card:hover::before {
    opacity: 1;
  }

  .fb-embed {
    width: 100%;
    background: #000;
    position: relative;
  }

  .fb-embed iframe {
    width: 100%;
    height: 280px;
    border: none;
  }

  .fb-info {
    padding: 14px 16px;
  }

  .fb-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fb-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 6px;
  }

  .fb-placeholder {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px;
    color: var(--text-muted);
  }

  .fb-placeholder-icon {
    font-size: 2.5rem;
    margin-bottom: 12px;
    animation: float 3s ease-in-out infinite;
  }

  @media (max-width: 600px) {
    .fb-grid {
      grid-template-columns: 1fr;
    }

    .fb-embed iframe {
      height: 220px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var grid = document.getElementById('fbGrid');
    if (!grid) return;

    fetch('/facebook-videos.json')
      .then(function(r) {
        if (!r.ok) throw new Error('not found');
        return r.json();
      })
      .then(function(videos) {
        if (!videos || videos.length === 0) {
          grid.innerHTML = '<div class="fb-placeholder"><div class="fb-placeholder-icon">📺</div><p>Videos coming soon!</p></div>';
          return;
        }

        grid.innerHTML = videos.map(function(video) {
          var embedUrl = 'https://www.facebook.com/plugins/video.php?href='
            + encodeURIComponent(video.permalink_url)
            + '&show_text=false&width=560';
          var title = video.title || video.description || 'Video Update';
          var date = '';
          if (video.created_time) {
            date = new Date(video.created_time).toLocaleDateString('en-US', {
              month: 'short', day: 'numeric', year: 'numeric'
            });
          }

          return ''
            + '<div class="fb-card">'
            + '<div class="fb-embed">'
            + '<iframe src="' + embedUrl + '"'
            + ' scrolling="no"'
            + ' allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"'
            + ' allowfullscreen loading="lazy"></iframe>'
            + '</div>'
            + '<div class="fb-info">'
            + '<p class="fb-title">' + title + '</p>'
            + (date ? '<p class="fb-date">' + date + '</p>' : '')
            + '</div>'
            + '</div>';
        }).join('');
      })
      .catch(function() {
        grid.innerHTML = '<div class="fb-placeholder"><div class="fb-placeholder-icon">📺</div><p>Videos coming soon!</p></div>';
      });
  });
</script>
