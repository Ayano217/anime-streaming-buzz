---
export interface Props {
  pageId?: string;
}
const { pageId = "" } = Astro.props;
---

<section class="fb-video-section section">
  <div class="container">
    <h2 class="section-title">📱 Latest Video Updates</h2>
    <div class="fb-videos-grid" id="fbVideosGrid">
      <div class="fb-loading">Loading videos...</div>
    </div>
  </div>
</section>

<style>
  .fb-video-section {
    background: var(--bg-secondary);
    padding: 40px 0;
    border-top: 1px solid var(--border-color);
  }

  .fb-videos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 20px;
  }

  .fb-video-card {
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
  }

  .fb-video-card:hover {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-glow-pink);
  }

  .fb-video-embed {
    position: relative;
    width: 100%;
    min-height: 250px;
    background: #000;
  }

  .fb-video-embed iframe {
    width: 100%;
    height: 250px;
    border: none;
  }

  .fb-video-info {
    padding: 12px;
  }

  .fb-video-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-primary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fb-loading {
    grid-column: 1/-1;
    text-align: center;
    padding: 40px;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .fb-videos-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .fb-videos-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  async function loadFBVideos() {
    const grid = document.getElementById('fbVideosGrid');
    if (!grid) return;

    try {
      const res = await fetch('/facebook-videos.json');
      if (!res.ok) throw new Error('No videos');
      const videos = await res.json();

      if (!videos || videos.length === 0) {
        grid.innerHTML = '<p class="fb-loading">No videos available yet.</p>';
        return;
      }

      grid.innerHTML = videos.map(video => `
        <div class="fb-video-card">
          <div class="fb-video-embed">
            <iframe
              src="https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(video.permalink_url)}&show_text=false&width=400"
              scrolling="no"
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy">
            </iframe>
          </div>
          <div class="fb-video-info">
            <p class="fb-video-title">${video.title || video.description || 'Video Update'}</p>
          </div>
        </div>
      `).join('');

    } catch (e) {
      grid.innerHTML = '<p class="fb-loading">Videos coming soon.</p>';
    }
  }

  document.addEventListener('DOMContentLoaded', loadFBVideos);
</script>
