---
// FacebookVideos.astro — Premium reel-style video section
// Loads from /facebook-videos.json (generated by fetch_facebook_videos.py)
---

<section class="fb-section" id="latest-videos">
  <div class="fb-container">

    <!-- Header -->
    <div class="fb-header">
      <div class="fb-label-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        Latest Videos
      </div>
      <h2 class="fb-title">Watch Our <span class="grad">Anime Content</span></h2>
      <p class="fb-sub">Fresh anime clips and highlights from our Facebook Page</p>
    </div>

    <!-- Skeleton (shown while loading) -->
    <div id="fb-skeleton" class="fb-grid">
      {Array(6).fill(0).map(() => (
        <div class="fb-skeleton-card">
          <div class="fb-skeleton-thumb"></div>
          <div class="fb-skeleton-lines">
            <div class="skel-line long"></div>
            <div class="skel-line short"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Error state -->
    <div id="fb-error" class="fb-error-box" style="display:none;">
      <span class="fb-error-icon">📡</span>
      <p class="fb-error-msg">Videos temporarily unavailable. Visit us directly on Facebook.</p>
      <a id="fb-page-btn" href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="fb-visit-btn">
        Visit our Facebook Page →
      </a>
    </div>

    <!-- Video grid -->
    <div id="fb-grid" class="fb-grid" style="display:none;" role="list"></div>

    <!-- Load more -->
    <div id="fb-more-wrap" style="display:none; text-align:center; margin-top:1.5rem;">
      <button id="fb-more-btn" class="fb-more-btn">Load More Videos</button>
      <p id="fb-more-count" class="fb-count-text"></p>
    </div>

  </div>

  <!-- ── Modal ── -->
  <div id="fb-modal" class="fb-modal" style="display:none;" role="dialog" aria-modal="true">
    <div id="fb-modal-bg" class="fb-modal-bg"></div>
    <div class="fb-modal-box">
      <button id="fb-modal-close" class="fb-modal-close" aria-label="Close">✕</button>

      <!-- Embed area -->
      <div id="fb-embed-area" class="fb-embed-area">
        <!-- Facebook iframe OR fallback button injected here -->
      </div>

      <!-- Modal footer -->
      <div id="fb-modal-footer" class="fb-modal-footer"></div>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  'use strict';

  const PER_PAGE = 6;
  let allVideos  = [];
  let pageNum    = 1;
  let pageUrl    = 'https://www.facebook.com';

  // DOM
  const skeleton   = document.getElementById('fb-skeleton');
  const errorBox   = document.getElementById('fb-error');
  const grid       = document.getElementById('fb-grid');
  const moreWrap   = document.getElementById('fb-more-wrap');
  const moreBtn    = document.getElementById('fb-more-btn');
  const moreCount  = document.getElementById('fb-more-count');
  const modal      = document.getElementById('fb-modal');
  const modalBg    = document.getElementById('fb-modal-bg');
  const modalClose = document.getElementById('fb-modal-close');
  const embedArea  = document.getElementById('fb-embed-area');
  const modalFoot  = document.getElementById('fb-modal-footer');

  // ── Utilities ──────────────────────────────────────────────────────────────

  function fmtDuration(sec) {
    const s = parseInt(sec, 10);
    if (!s || s <= 0) return '';
    const m = Math.floor(s / 60), r = s % 60;
    return m + ':' + String(r).padStart(2, '0');
  }

  function fmtDate(str) {
    if (!str) return '';
    try {
      return new Date(str).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    } catch { return ''; }
  }

  function fmtViews(n) {
    if (!n) return '';
    if (n >= 1e6) return (n / 1e6).toFixed(1) + 'M views';
    if (n >= 1e3) return (n / 1e3).toFixed(1) + 'K views';
    return n + ' views';
  }

  function truncate(str, max) {
    if (!str) return '';
    return str.length <= max ? str : str.slice(0, max).trimEnd() + '…';
  }

  function escape(str) {
    return (str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // ── Card HTML ──────────────────────────────────────────────────────────────

  function cardHTML(v) {
    const thumb    = v.full_picture || v.picture || '';
    const title    = truncate(v.title || v.description || 'Watch Video', 80);
    const dur      = fmtDuration(v.length);
    const date     = fmtDate(v.created_time);
    const views    = fmtViews(v.views);

    return `
      <article
        class="fb-card"
        role="listitem"
        tabindex="0"
        data-id="${escape(v.id)}"
        data-embed="${escape(v.embed_url || '')}"
        data-url="${escape(v.permalink_url || '')}"
        data-title="${escape(title)}"
        aria-label="Play: ${escape(title)}"
      >
        <div class="fb-card-thumb">
          ${thumb
            ? `<img src="${escape(thumb)}" alt="${escape(title)}" loading="lazy" class="fb-thumb-img" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
            : ''}
          <div class="fb-thumb-fallback" style="${thumb ? 'display:none' : 'display:flex'}">🎬</div>
          <div class="fb-card-overlay">
            <div class="fb-play-circle">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
            </div>
          </div>
          ${dur ? `<span class="fb-dur">${escape(dur)}</span>` : ''}
          <div class="fb-thumb-grad"></div>
        </div>
        <div class="fb-card-info">
          <p class="fb-card-title">${escape(title)}</p>
          <div class="fb-card-meta">
            ${date  ? `<span>${escape(date)}</span>` : ''}
            ${views ? `<span>${escape(views)}</span>` : ''}
          </div>
        </div>
      </article>
    `;
  }

  // ── Render page ────────────────────────────────────────────────────────────

  function render() {
    const end   = pageNum * PER_PAGE;
    const slice = allVideos.slice(0, end);
    grid.innerHTML = slice.map(cardHTML).join('');

    // Attach click listeners
    grid.querySelectorAll('.fb-card').forEach(card => {
      const open = () => openModal(card);
      card.addEventListener('click', open);
      card.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); }
      });
    });

    // Load more
    if (end < allVideos.length) {
      moreWrap.style.display = 'block';
      moreCount.textContent  = `Showing ${end} of ${allVideos.length} videos`;
      moreBtn.style.display  = 'inline-flex';
    } else {
      moreBtn.style.display = 'none';
      moreCount.textContent = allVideos.length > PER_PAGE
        ? `All ${allVideos.length} videos shown` : '';
      moreWrap.style.display = allVideos.length > PER_PAGE ? 'block' : 'none';
    }
  }

  moreBtn.addEventListener('click', () => {
    pageNum++;
    render();
  });

  // ── Modal ──────────────────────────────────────────────────────────────────

  function openModal(card) {
    const embedUrl  = card.dataset.embed  || '';
    const watchUrl  = card.dataset.url    || '';
    const title     = card.dataset.title  || 'Watch Video';

    // Always show Watch on Facebook button immediately (embed is unreliable)
    // AND try to embed — if embed fails the button is already visible
    embedArea.innerHTML = buildEmbedHTML(embedUrl, watchUrl, title);
    modalFoot.innerHTML = buildFooterHTML(title, watchUrl);

    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    setTimeout(() => modalClose.focus(), 50);
  }

  function buildEmbedHTML(embedUrl, watchUrl, title) {
    // Show both: iframe embed attempt + "Watch on Facebook" button
    // The button is always visible so if embed fails, user has a working option
    const iframeHtml = embedUrl ? `
      <div class="fb-iframe-wrap">
        <iframe
          src="${escape(embedUrl)}"
          width="100%"
          height="100%"
          style="border:none;overflow:hidden;"
          scrolling="no"
          frameborder="0"
          allowfullscreen="true"
          allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
          title="${escape(title)}"
          id="fb-iframe"
        ></iframe>
      </div>
    ` : '';

    const watchBtnHtml = watchUrl ? `
      <div class="fb-watch-btn-wrap">
        <a href="${escape(watchUrl)}" target="_blank" rel="noopener noreferrer" class="fb-watch-fb-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="flex-shrink:0"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          Watch on Facebook
        </a>
        <p class="fb-embed-note">If the video doesn't load above, click the button to watch directly on Facebook.</p>
      </div>
    ` : '';

    return iframeHtml + watchBtnHtml;
  }

  function buildFooterHTML(title, watchUrl) {
    return `
      <span class="fb-modal-title-text">${escape(truncate(title, 60))}</span>
      ${watchUrl ? `<a href="${escape(watchUrl)}" target="_blank" rel="noopener noreferrer" class="fb-open-link">Open on Facebook ↗</a>` : ''}
    `;
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    embedArea.innerHTML = '';   // stop video
    modalFoot.innerHTML = '';
  }

  modalClose.addEventListener('click', closeModal);
  modalBg.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });

  // ── Init / Fetch ───────────────────────────────────────────────────────────

  async function init() {
    try {
      const res  = await fetch('/facebook-videos.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const json = await res.json();

      // Support both array and { videos: [...] } formats
      let videos = [];
      if (Array.isArray(json))               videos = json;
      else if (Array.isArray(json.videos))   videos = json.videos;
      else if (Array.isArray(json.data))     videos = json.data;

      if (json.page_url) {
        pageUrl = json.page_url;
        const btn = document.getElementById('fb-page-btn');
        if (btn) btn.href = pageUrl;
      }

      // Filter: only include videos with at least an id or permalink_url
      allVideos = videos.filter(v => v && (v.id || v.permalink_url));

      skeleton.style.display = 'none';

      if (allVideos.length === 0) {
        errorBox.style.display = 'flex';
        return;
      }

      grid.style.display = 'grid';
      render();

    } catch (err) {
      console.warn('[FB Videos] Load failed:', err);
      skeleton.style.display = 'none';
      errorBox.style.display = 'flex';
    }
  }

  init();
})();
</script>

<style>
  /* ── Section ── */
  .fb-section {
    padding: 4rem 0;
    position: relative;
  }

  .fb-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .fb-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .fb-label-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    background: rgba(139,0,255,0.1);
    border: 1px solid rgba(139,0,255,0.3);
    color: #c084fc;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .fb-title {
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 0.4rem;
  }

  .grad {
    background: linear-gradient(135deg, #c084fc, #00d4ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .fb-sub {
    color: rgba(255,255,255,0.4);
    font-size: 0.88rem;
    margin: 0;
  }

  /* ── Grid ── */
  .fb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.1rem;
  }

  /* ── Skeleton ── */
  .fb-skeleton-card {
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
  }

  .fb-skeleton-thumb {
    aspect-ratio: 3/4;
    background: linear-gradient(90deg, rgba(255,255,255,0.04) 25%, rgba(255,255,255,0.08) 50%, rgba(255,255,255,0.04) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  .fb-skeleton-lines {
    padding: 0.65rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .skel-line {
    height: 9px;
    border-radius: 4px;
    background: rgba(255,255,255,0.06);
    animation: shimmer 1.5s infinite;
  }
  .skel-line.long  { width: 80%; }
  .skel-line.short { width: 50%; }

  @keyframes shimmer {
    0%   { background-position: -200% 0; }
    100% { background-position:  200% 0; }
  }

  /* ── Error Box ── */
  .fb-error-box {
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 2.5rem 1.5rem;
    background: rgba(139,0,255,0.05);
    border: 1px solid rgba(139,0,255,0.15);
    border-radius: 16px;
    text-align: center;
  }

  .fb-error-icon { font-size: 2rem; }

  .fb-error-msg {
    color: rgba(255,255,255,0.5);
    font-size: 0.88rem;
    margin: 0;
  }

  .fb-visit-btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: #1877F2;
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.84rem;
    transition: background 0.2s;
  }
  .fb-visit-btn:hover { background: #0f65d4; }

  /* ── Video Card ── */
  .fb-card {
    background: rgba(10,10,20,0.7);
    border: 1px solid rgba(139,0,255,0.15);
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    display: flex;
    flex-direction: column;
    outline: none;
  }

  .fb-card:hover,
  .fb-card:focus-visible {
    transform: translateY(-5px);
    border-color: rgba(139,0,255,0.5);
    box-shadow: 0 10px 35px rgba(139,0,255,0.2);
  }

  /* Thumbnail — 3:4 ratio */
  .fb-card-thumb {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: rgba(20,0,40,0.5);
    flex-shrink: 0;
  }

  .fb-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s;
  }

  .fb-card:hover .fb-thumb-img { transform: scale(1.07); }

  .fb-thumb-fallback {
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    opacity: 0.3;
    background: linear-gradient(135deg, rgba(139,0,255,0.1), rgba(0,212,255,0.05));
  }

  /* Play overlay */
  .fb-card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0,0,0,0);
    transition: background 0.25s;
  }
  .fb-card:hover .fb-card-overlay { background: rgba(0,0,0,0.3); }

  .fb-play-circle {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: rgba(139,0,255,0.88);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.75);
    transition: opacity 0.25s, transform 0.25s;
    box-shadow: 0 0 20px rgba(139,0,255,0.5);
  }
  .fb-card:hover .fb-play-circle,
  .fb-card:focus-visible .fb-play-circle {
    opacity: 1;
    transform: scale(1);
  }

  .fb-dur {
    position: absolute;
    bottom: 7px;
    right: 7px;
    background: rgba(0,0,0,0.75);
    color: #fff;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.12rem 0.35rem;
    border-radius: 4px;
    backdrop-filter: blur(3px);
  }

  .fb-thumb-grad {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 35%;
    background: linear-gradient(transparent, rgba(0,0,0,0.55));
    pointer-events: none;
  }

  /* Card info */
  .fb-card-info {
    padding: 0.65rem 0.8rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .fb-card-title {
    font-size: 0.79rem;
    font-weight: 600;
    color: rgba(255,255,255,0.88);
    margin: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .fb-card-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    font-size: 0.68rem;
    color: rgba(255,255,255,0.35);
  }

  /* ── Load More ── */
  .fb-more-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.75rem;
    background: transparent;
    border: 1.5px solid rgba(139,0,255,0.4);
    color: rgba(255,255,255,0.7);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
  }
  .fb-more-btn:hover {
    background: rgba(139,0,255,0.15);
    border-color: rgba(139,0,255,0.7);
    color: #fff;
  }

  .fb-count-text {
    color: rgba(255,255,255,0.25);
    font-size: 0.75rem;
    margin: 0.4rem 0 0;
  }

  /* ── Modal ── */
  .fb-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .fb-modal-bg {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(8px);
  }

  .fb-modal-box {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 720px;
    background: rgba(8,4,20,0.98);
    border: 1px solid rgba(139,0,255,0.3);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 80px rgba(0,0,0,0.8), 0 0 40px rgba(139,0,255,0.12);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
  }

  .fb-modal-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    z-index: 10;
    background: rgba(0,0,0,0.65);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    font-family: inherit;
    line-height: 1;
  }
  .fb-modal-close:hover {
    background: rgba(139,0,255,0.45);
    border-color: rgba(139,0,255,0.6);
  }

  /* Embed area */
  .fb-embed-area {
    flex: 1;
    overflow-y: auto;
    background: #000;
  }

  .fb-iframe-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
  }

  .fb-iframe-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Watch on Facebook button — always visible in modal */
  .fb-watch-btn-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    background: rgba(10,5,20,0.95);
    border-top: 1px solid rgba(255,255,255,0.07);
  }

  .fb-watch-fb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    background: #1877F2;
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: background 0.2s, transform 0.2s;
  }
  .fb-watch-fb-btn:hover {
    background: #0f65d4;
    transform: translateY(-1px);
  }

  .fb-embed-note {
    color: rgba(255,255,255,0.35);
    font-size: 0.73rem;
    margin: 0;
    text-align: center;
  }

  /* Modal footer */
  .fb-modal-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    gap: 1rem;
    background: rgba(8,4,20,0.98);
    flex-shrink: 0;
  }

  .fb-modal-title-text {
    color: rgba(255,255,255,0.75);
    font-size: 0.82rem;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }

  .fb-open-link {
    color: rgba(139,0,255,0.8);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .fb-open-link:hover { color: #8b00ff; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .fb-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .fb-modal-box { max-width: 100%; border-radius: 12px; }
  }

  @media (max-width: 400px) {
    .fb-grid { grid-template-columns: repeat(2, 1fr); gap: 0.65rem; }
  }
</style>
