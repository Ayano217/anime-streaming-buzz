---

---

<section class="video-section section">
  <div class="container">
    <div class="video-header">
      <h2 class="section-title">🎬 Video Updates</h2>
      <p class="video-subtitle">Latest videos from our channel</p>
    </div>

    <div class="video-grid" id="videoGrid">
      <!-- Skeleton loading -->
      <div class="video-skeleton skeleton"></div>
      <div class="video-skeleton skeleton"></div>
      <div class="video-skeleton skeleton"></div>
    </div>

    <div class="video-load-more-wrap" id="loadMoreWrap" style="display:none;">
      <button class="btn-primary" id="loadMoreBtn">Load More Videos</button>
    </div>
  </div>
</section>

<style>
  .video-section {
    padding: 56px 0;
    position: relative;
    overflow: hidden;
  }

  .video-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(24, 119, 242, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 50%, rgba(136, 51, 255, 0.04) 0%, transparent 60%);
    pointer-events: none;
  }

  .video-header {
    margin-bottom: 32px;
  }

  .video-subtitle {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: -20px;
    margin-left: 16px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    position: relative;
  }

  .video-skeleton {
    height: 320px;
    border-radius: var(--radius-lg);
  }

  /* Video Card */
  .vid-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    transition: all var(--transition-normal);
    position: relative;
    cursor: pointer;
  }

  .vid-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #1877f2, #8833ff, #00ccff);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: 3;
  }

  .vid-card:hover {
    transform: translateY(-6px);
    border-color: rgba(24, 119, 242, 0.3);
    box-shadow:
      0 12px 40px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(24, 119, 242, 0.1);
  }

  .vid-card:hover::before {
    opacity: 1;
  }

  /* Thumbnail */
  .vid-thumb {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: #000;
  }

  .vid-thumb iframe {
    width: 100%;
    height: 100%;
    border: none;
    transition: transform var(--transition-slow);
  }

  .vid-card:hover .vid-thumb iframe {
    transform: scale(1.03);
  }

  /* Play overlay */
  .vid-play-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
    pointer-events: none;
    z-index: 2;
  }

  .vid-card:hover .vid-play-overlay {
    opacity: 1;
  }

  .play-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 30px rgba(255, 51, 102, 0.4);
    animation: pulse-glow 2s infinite;
  }

  .play-icon svg {
    width: 24px;
    height: 24px;
    fill: #fff;
    margin-left: 3px;
  }

  /* Info */
  .vid-info {
    padding: 16px 18px;
    position: relative;
  }

  .vid-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 8px;
    transition: color var(--transition-fast);
  }

  .vid-card:hover .vid-title {
    color: var(--accent-primary);
  }

  .vid-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .vid-source {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    border-radius: var(--radius-round);
    background: rgba(24, 119, 242, 0.1);
    color: #4b9bff;
    font-weight: 600;
    font-size: 0.7rem;
  }

  /* No videos */
  .vid-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 24px;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px dashed var(--border-color);
  }

  .vid-empty-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
    animation: float 3s ease-in-out infinite;
  }

  .vid-empty p {
    color: var(--text-muted);
    font-size: 1rem;
  }

  .video-load-more-wrap {
    text-align: center;
    margin-top: 32px;
  }

  @media (max-width: 600px) {
    .video-grid {
      grid-template-columns: 1fr;
    }

    .vid-thumb {
      height: 180px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var grid = document.getElementById('videoGrid');
    var loadMoreWrap = document.getElementById('loadMoreWrap');
    var loadMoreBtn = document.getElementById('loadMoreBtn');
    if (!grid) return;

    var allVideos = [];
    var showCount = 6;

    function timeAgo(dateStr) {
      if (!dateStr) return '';
      var now = new Date();
      var date = new Date(dateStr);
      var diff = Math.floor((now - date) / 1000);
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      if (diff < 2592000) return Math.floor(diff / 86400) + 'd ago';
      return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    function renderVideos() {
      var visible = allVideos.slice(0, showCount);

      grid.innerHTML = visible.map(function(video, index) {
        var embedUrl = 'https://www.facebook.com/plugins/video.php?href='
          + encodeURIComponent(video.permalink_url)
          + '&show_text=false&width=560&height=314';
        var title = (video.title || video.description || 'Video Update').substring(0, 80);
        var time = timeAgo(video.created_time);
        var delay = index * 0.08;

        return ''
          + '<div class="vid-card" style="animation:fadeInUp 0.5s ease forwards;animation-delay:' + delay + 's;opacity:0;">'

          + '<div class="vid-thumb">'
          + '<iframe src="' + embedUrl + '"'
          + ' scrolling="no"'
          + ' allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"'
          + ' allowfullscreen loading="lazy"></iframe>'
          + '<div class="vid-play-overlay">'
          + '<div class="play-icon">'
          + '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'
          + '</div>'
          + '</div>'
          + '</div>'

          + '<div class="vid-info">'
          + '<p class="vid-title">' + title + '</p>'
          + '<div class="vid-meta">'
          + '<span class="vid-source">📘 Facebook</span>'
          + (time ? '<span>' + time + '</span>' : '')
          + '</div>'
          + '</div>'

          + '</div>';
      }).join('');

      // Load more button
      if (showCount < allVideos.length) {
        var remaining = allVideos.length - showCount;
        loadMoreBtn.textContent = 'Load More (' + remaining + ' more)';
        loadMoreWrap.style.display = 'block';
      } else {
        loadMoreWrap.style.display = 'none';
      }
    }

    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', function() {
        showCount += 6;
        renderVideos();
        // Smooth scroll to new content
        setTimeout(function() {
          var cards = grid.querySelectorAll('.vid-card');
          if (cards.length > 0) {
            cards[cards.length - 1].scrollIntoView({
              behavior: 'smooth',
              block: 'center'
            });
          }
        }, 100);
      });
    }

    fetch('/facebook-videos.json')
      .then(function(r) {
        if (!r.ok) throw new Error('not found');
        return r.json();
      })
      .then(function(videos) {
        if (!videos || videos.length === 0) {
          grid.innerHTML = ''
            + '<div class="vid-empty">'
            + '<span class="vid-empty-icon">🎬</span>'
            + '<p>Videos coming soon! Stay tuned.</p>'
            + '</div>';
          return;
        }
        allVideos = videos;
        renderVideos();
      })
      .catch(function() {
        grid.innerHTML = ''
          + '<div class="vid-empty">'
          + '<span class="vid-empty-icon">🎬</span>'
          + '<p>Videos coming soon! Stay tuned.</p>'
          + '</div>';
      });
  });
</script>
