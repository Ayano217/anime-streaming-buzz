---

---

<section class="video-section section">
  <div class="container">
    <div class="video-header">
      <h2 class="section-title">🎬 Our Videos</h2>
      <p class="video-subtitle">Watch our latest anime content</p>
    </div>
    <div class="video-grid" id="videoGrid">
      <div class="vid-empty">
        <span class="vid-empty-icon">🎬</span>
        <p>Loading videos...</p>
      </div>
    </div>
    <div class="video-load-wrap" id="loadWrap" style="display:none;">
      <button class="btn-primary" id="loadBtn">Load More Videos</button>
    </div>
  </div>
</section>

<style>
  .video-section {
    padding: 48px 0;
    position: relative;
  }

  .video-header {
    margin-bottom: 28px;
  }

  .video-subtitle {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin-top: -18px;
    margin-left: 16px;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .vid-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: all var(--transition-normal);
    text-decoration: none;
    display: block;
    position: relative;
  }

  .vid-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, #1877f2, #8833ff);
    opacity: 0;
    transition: opacity var(--transition-fast);
    z-index: 2;
  }

  .vid-card:hover {
    transform: translateY(-6px);
    border-color: rgba(24, 119, 242, 0.3);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3), 0 0 20px rgba(24, 119, 242, 0.1);
  }

  .vid-card:hover::before {
    opacity: 1;
  }

  .vid-thumb {
    position: relative;
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .vid-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .vid-card:hover .vid-thumb-img {
    transform: scale(1.08);
  }

  .vid-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--accent-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 30px rgba(255, 51, 102, 0.4);
    transition: all var(--transition-fast);
  }

  .vid-card:hover .vid-play-btn {
    transform: translate(-50%, -50%) scale(1.1);
    box-shadow: 0 0 40px rgba(255, 51, 102, 0.6);
  }

  .vid-play-btn svg {
    width: 24px;
    height: 24px;
    fill: #fff;
    margin-left: 3px;
  }

  .vid-duration {
    position: absolute;
    bottom: 8px;
    right: 8px;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .vid-info {
    padding: 14px 16px;
  }

  .vid-title {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 8px;
    transition: color var(--transition-fast);
  }

  .vid-card:hover .vid-title {
    color: var(--accent-primary);
  }

  .vid-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .vid-source-badge {
    padding: 2px 10px;
    border-radius: var(--radius-round);
    background: rgba(24, 119, 242, 0.1);
    color: #4b9bff;
    font-weight: 600;
    font-size: 0.7rem;
  }

  .vid-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px dashed var(--border-color);
  }

  .vid-empty-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: 12px;
    animation: float 3s ease-in-out infinite;
  }

  .vid-empty p {
    color: var(--text-muted);
  }

  .video-load-wrap {
    text-align: center;
    margin-top: 28px;
  }

  @media (max-width: 600px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var grid = document.getElementById('videoGrid');
    var loadWrap = document.getElementById('loadWrap');
    var loadBtn = document.getElementById('loadBtn');
    if (!grid) return;

    var allVideos = [];
    var showCount = 9;

    function timeAgo(dateStr) {
      if (!dateStr) return '';
      var diff = Math.floor((new Date() - new Date(dateStr)) / 1000);
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      if (diff < 2592000) return Math.floor(diff / 86400) + 'd ago';
      return new Date(dateStr).toLocaleDateString('en-US', {
        month: 'short', day: 'numeric'
      });
    }

    function formatDuration(seconds) {
      if (!seconds) return '';
      var m = Math.floor(seconds / 60);
      var s = Math.floor(seconds % 60);
      return m + ':' + (s < 10 ? '0' : '') + s;
    }

    function getVideoThumb(video) {
      var id = video.id || '';
      return 'https://graph.facebook.com/' + id + '/thumbnails';
    }

    function renderVideos() {
      var visible = allVideos.slice(0, showCount);

      grid.innerHTML = visible.map(function(video, i) {
        var title = (video.title || video.description || 'Video Update').substring(0, 80);
        var time = timeAgo(video.created_time);
        var duration = formatDuration(video.length);
        var fbUrl = 'https://www.facebook.com' + (video.permalink_url || '');
        var thumbUrl = 'https://picsum.photos/seed/fb-' + (video.id || i) + '/600/340';
        var delay = i * 0.06;

        return ''
          + '<a href="' + fbUrl + '" target="_blank" rel="noopener" class="vid-card"'
          + ' style="animation:fadeInUp 0.5s ease forwards;animation-delay:' + delay + 's;opacity:0;">'

          + '<div class="vid-thumb">'
          + '<img class="vid-thumb-img" src="' + thumbUrl + '" alt="' + title + '" loading="lazy" />'
          + '<div class="vid-play-btn">'
          + '<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'
          + '</div>'
          + (duration ? '<span class="vid-duration">' + duration + '</span>' : '')
          + '</div>'

          + '<div class="vid-info">'
          + '<p class="vid-title">' + title + '</p>'
          + '<div class="vid-meta">'
          + '<span class="vid-source-badge">📘 Facebook</span>'
          + (time ? '<span>' + time + '</span>' : '')
          + '</div>'
          + '</div>'

          + '</a>';
      }).join('');

      if (showCount < allVideos.length) {
        var remaining = allVideos.length - showCount;
        loadBtn.textContent = 'Load More (' + remaining + ' remaining)';
        loadWrap.style.display = 'block';
      } else {
        loadWrap.style.display = 'none';
      }
    }

    if (loadBtn) {
      loadBtn.addEventListener('click', function() {
        showCount += 9;
        renderVideos();
      });
    }

    fetch('/facebook-videos.json')
      .then(function(r) {
        if (!r.ok) throw new Error('fail');
        return r.json();
      })
      .then(function(videos) {
        if (!videos || videos.length === 0) {
          grid.innerHTML = '<div class="vid-empty"><span class="vid-empty-icon">🎬</span><p>Videos coming soon!</p></div>';
          return;
        }
        allVideos = videos;
        renderVideos();
      })
      .catch(function() {
        grid.innerHTML = '<div class="vid-empty"><span class="vid-empty-icon">🎬</span><p>Videos coming soon!</p></div>';
      });
  });
</script>
