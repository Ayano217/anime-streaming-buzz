---
import { adSlots } from '../config/ads';

export interface Props {
  slot?: string;
  size?: string;
  label?: string;
}

const {
  slot: adSlot = "default",
  size = "728x90",
  label = "Advertisement"
} = Astro.props;

const adMarkup = adSlots[adSlot] ?? '';
const hasAd = adMarkup.trim().length > 0;
---

<div class="ad-container" data-ad-slot={adSlot} data-ad-size={size}>
  <div class="ad-wrapper">
    <span class="ad-label">{label}</span>

    {hasAd ? (
      <div class="ad-live" set:html={adMarkup}></div>
    ) : (
      <div class="ad-content">Ad Space</div>
    )}
  </div>
</div>

<style>
  .ad-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 20px 0;
  }

  .ad-wrapper {
    text-align: center;
    width: 100%;
    max-width: 728px;
  }

  .ad-label {
    display: block;
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }

  .ad-content,
  .ad-live {
    min-height: 90px;
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-card);
    overflow: hidden;
  }

  .ad-content {
    border: 1px dashed var(--border-color);
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  @media (max-width: 768px) {
    .ad-wrapper { max-width: 100%; }
    .ad-content,
    .ad-live { min-height: 60px; }
  }
</style>
