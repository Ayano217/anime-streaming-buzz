---
import { adSlots } from '../config/ads';

export interface Props {
  slot?: string;
  size?: string;
  label?: string;
}

const {
  slot: adSlot = "default"
} = Astro.props;

const adMarkup = adSlots[adSlot] ?? '';
const hasAd = adMarkup.trim().length > 0;
---

{hasAd && (
  <div class="ad-container" data-ad-slot={adSlot}>
    <div class="ad-wrapper">
      <div class="ad-live" set:html={adMarkup}></div>
    </div>
  </div>
)}

<style>
  .ad-container {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 20px 0;
  }

  .ad-wrapper {
    width: 100%;
    max-width: 728px;
  }

  .ad-live {
    min-height: 90px;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .ad-live { min-height: 60px; }
  }
</style>
