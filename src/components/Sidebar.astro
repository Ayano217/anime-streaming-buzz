---
export interface SidePost {
  title: string;
  slug: string;
  image: string;
  category: string;
  date: string;
}

export interface Props {
  trendingPosts?: SidePost[];
  recentPosts?: SidePost[];
}

const { trendingPosts = [], recentPosts = [] } = Astro.props;
---

<aside class="sidebar">

  {trendingPosts.length > 0 && (
    <div class="sidebar-block">
      <div class="sidebar-header">
        <span class="sidebar-icon">🔥</span>
        <h3 class="sidebar-title">Popular</h3>
      </div>
      <div class="sidebar-list">
        {trendingPosts.map((post, i) => (
          <a href={post.slug} class="sidebar-item" style={`animation-delay: ${i * 0.08}s`}>
            <div class="sidebar-rank-circle">
              <span>{i + 1}</span>
            </div>
            <div class="sidebar-thumb">
              <img src={post.image} alt={post.title} loading="lazy" />
            </div>
            <div class="sidebar-text">
              <span class="sidebar-cat">{post.category}</span>
              <h4 class="sidebar-item-title">{post.title}</h4>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {recentPosts.length > 0 && (
    <div class="sidebar-block">
      <div class="sidebar-header">
        <span class="sidebar-icon">🕐</span>
        <h3 class="sidebar-title">Recent</h3>
      </div>
      <div class="sidebar-list">
        {recentPosts.map((post, i) => (
          <a href={post.slug} class="sidebar-item" style={`animation-delay: ${i * 0.08}s`}>
            <div class="sidebar-thumb">
              <img src={post.image} alt={post.title} loading="lazy" />
            </div>
            <div class="sidebar-text">
              <span class="sidebar-cat">{post.category}</span>
              <h4 class="sidebar-item-title">{post.title}</h4>
              <span class="sidebar-date">{post.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Newsletter -->
  <div class="sidebar-block sidebar-newsletter">
    <div class="newsletter-glow"></div>
    <span class="newsletter-icon">📬</span>
    <h3 class="newsletter-title">Stay Updated</h3>
    <p class="newsletter-desc">Get the latest anime news delivered to your inbox.</p>
    <form class="newsletter-form" onsubmit="event.preventDefault(); this.querySelector('.newsletter-success').style.display='block'; this.querySelector('button').textContent='Subscribed ✓';">
      <input type="email" placeholder="your@email.com" class="newsletter-input" required />
      <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">Subscribe</button>
      <p class="newsletter-success" style="display:none; color: var(--accent-green); font-size:0.82rem; margin-top:8px;">Thanks for subscribing!</p>
    </form>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--header-height) + 24px);
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sidebar-block {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px;
    transition: border-color var(--transition-fast);
  }

  .sidebar-block:hover {
    border-color: rgba(255, 51, 102, 0.15);
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--accent-primary);
  }

  .sidebar-icon {
    font-size: 1.1rem;
  }

  .sidebar-title {
    font-size: 1rem;
    font-weight: 700;
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sidebar-item {
    display: flex;
    gap: 10px;
    padding: 8px;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-fast);
    align-items: center;
    animation: fadeInUp 0.4s ease forwards;
    opacity: 0;
  }

  .sidebar-item:hover {
    background: var(--bg-card-hover);
    transform: translateX(4px);
  }

  .sidebar-rank-circle {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 50%;
    background: var(--accent-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 800;
    color: #fff;
  }

  .sidebar-thumb {
    width: 56px;
    height: 56px;
    min-width: 56px;
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .sidebar-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .sidebar-item:hover .sidebar-thumb img {
    transform: scale(1.1);
  }

  .sidebar-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .sidebar-cat {
    font-size: 0.68rem;
    text-transform: uppercase;
    color: var(--accent-primary);
    font-weight: 700;
    letter-spacing: 0.5px;
  }

  .sidebar-item-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .sidebar-item:hover .sidebar-item-title {
    color: var(--accent-primary);
  }

  .sidebar-date {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  /* Newsletter */
  .sidebar-newsletter {
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .newsletter-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      circle at center,
      rgba(255, 51, 102, 0.05) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .newsletter-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 8px;
    animation: float 3s ease-in-out infinite;
  }

  .newsletter-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 6px;
    position: relative;
  }

  .newsletter-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-bottom: 14px;
    position: relative;
  }

  .newsletter-form {
    position: relative;
  }

  .newsletter-input {
    width: 100%;
    padding: 12px 16px;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-size: 0.88rem;
    font-family: var(--font-main);
    outline: none;
    margin-bottom: 10px;
    transition: border-color var(--transition-fast);
  }

  .newsletter-input:focus {
    border-color: var(--accent-primary);
    box-shadow: var(--glow-pink);
  }

  .newsletter-input::placeholder {
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    .sidebar-newsletter {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
