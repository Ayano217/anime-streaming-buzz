---
export interface SidePost {
  title: string;
  slug: string;
  image: string;
  category: string;
  date: string;
}

export interface Props {
  trendingPosts?: SidePost[];
  recentPosts?: SidePost[];
}

const { trendingPosts = [], recentPosts = [] } = Astro.props;
---

<aside class="sidebar">
  {trendingPosts.length > 0 && (
    <div class="sidebar-section">
      <h3 class="sidebar-title">🔥 Trending</h3>
      <div class="sidebar-list">
        {trendingPosts.map((post, i) => (
          <a href={post.slug} class="sidebar-card">
            <span class="sidebar-rank">{i + 1}</span>
            <img src={post.image} alt={post.title} loading="lazy" />
            <div class="sidebar-info">
              <span class="sidebar-cat">{post.category}</span>
              <h4>{post.title}</h4>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  {recentPosts.length > 0 && (
    <div class="sidebar-section">
      <h3 class="sidebar-title">🕐 Recent</h3>
      <div class="sidebar-list">
        {recentPosts.map((post) => (
          <a href={post.slug} class="sidebar-card">
            <img src={post.image} alt={post.title} loading="lazy" />
            <div class="sidebar-info">
              <span class="sidebar-cat">{post.category}</span>
              <h4>{post.title}</h4>
              <span class="sidebar-date">{post.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</aside>

<style>
  .sidebar {
    position: sticky;
    top: calc(var(--header-height) + 20px);
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .sidebar-section {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px;
  }

  .sidebar-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--accent-primary);
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sidebar-card {
    display: flex;
    gap: 10px;
    padding: 8px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--transition-fast);
    align-items: center;
  }

  .sidebar-card:hover {
    background: var(--bg-card-hover);
  }

  .sidebar-rank {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    min-width: 28px;
  }

  .sidebar-card img {
    width: 60px;
    height: 60px;
    border-radius: var(--radius-sm);
    object-fit: cover;
    flex-shrink: 0;
  }

  .sidebar-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .sidebar-cat {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--accent-primary);
    font-weight: 600;
  }

  .sidebar-info h4 {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sidebar-date {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  @media (max-width: 1024px) {
    .sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
