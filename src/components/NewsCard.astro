---
export interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  readTime: string;
  image: string;
  slug: string;
  badgeType?: string;
}

const {
  title,
  excerpt,
  category,
  date,
  readTime,
  image,
  slug,
  badgeType = "pink"
} = Astro.props;

const badgeClass = `badge badge-${badgeType}`;
---

<a href={slug} class="news-card premium-card">
  <div class="card-image-wrap">
    <img src={image} alt={title} loading="lazy" />
    <div class="card-image-overlay"></div>
    <span class={badgeClass}>{category}</span>
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-excerpt">{excerpt}</p>
    <div class="card-footer">
      <span class="card-date">{date}</span>
      <span class="card-dot">·</span>
      <span class="card-read">{readTime}</span>
    </div>
  </div>
  <div class="card-shine"></div>
</a>

<style>
  .news-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .news-card::before {
    height: 3px;
  }

  .card-image-wrap {
    position: relative;
    width: 100%;
    height: 220px;
    overflow: hidden;
  }

  .card-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .news-card:hover .card-image-wrap img {
    transform: scale(1.08);
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(11, 11, 20, 0.6) 0%,
      transparent 50%
    );
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .news-card:hover .card-image-overlay {
    opacity: 1;
  }

  .card-image-wrap .badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
  }

  .card-body {
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--transition-fast);
  }

  .news-card:hover .card-title {
    color: var(--accent-primary);
  }

  .card-excerpt {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--border-color);
  }

  .card-dot {
    color: var(--accent-primary);
  }

  /* Shine effect on hover */
  .card-shine {
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.03),
      transparent
    );
    transition: left 0.6s ease;
    pointer-events: none;
  }

  .news-card:hover .card-shine {
    left: 150%;
  }

  @media (max-width: 600px) {
    .card-image-wrap {
      height: 180px;
    }

    .card-body {
      padding: 14px;
    }

    .card-title {
      font-size: 0.95rem;
    }
  }
</style>
