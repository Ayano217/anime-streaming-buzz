---

---

<div class="search-page-box" id="searchPageBox">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.35-4.35"/>
    </svg>
    <input
      type="text"
      class="search-page-input"
      id="searchPageInput"
      placeholder="Search anime, manhwa, news..."
      autocomplete="off"
    />
    <button class="search-clear" id="searchClear">✕</button>
  </div>

  <div class="search-results" id="searchResults"></div>

  <div class="search-google" id="searchGoogle" style="display:none;">
    <p>Not found on site. Try Google:</p>
    <a id="googleSearchLink" href="#" target="_blank" class="google-btn">
      🔍 Search on Google
    </a>
  </div>
</div>

<style>
  .search-page-box {
    max-width: 700px;
    margin: 0 auto;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    background: var(--bg-card);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition-fast);
  }

  .search-input-wrapper:focus-within {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-glow-pink);
  }

  .search-icon {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .search-page-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: 1.1rem;
    font-family: var(--font-main);
    outline: none;
  }

  .search-page-input::placeholder {
    color: var(--text-muted);
  }

  .search-clear {
    border: none;
    background: transparent;
    color: var(--text-muted);
    font-size: 1.2rem;
    cursor: pointer;
    display: none;
  }

  .search-results {
    margin-top: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .search-google {
    margin-top: 20px;
    text-align: center;
    padding: 20px;
    background: var(--bg-card);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
  }

  .search-google p {
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .google-btn {
    display: inline-block;
    padding: 10px 24px;
    background: var(--accent-gradient);
    color: #fff;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .google-btn:hover {
    opacity: 0.9;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('searchPageInput');
    const results = document.getElementById('searchResults');
    const googleDiv = document.getElementById('searchGoogle');
    const googleLink = document.getElementById('googleSearchLink');
    const clearBtn = document.getElementById('searchClear');

    let posts = [];

    fetch('/search-index.json')
      .then(r => r.json())
      .then(data => { posts = data; })
      .catch(() => { posts = []; });

    function search(query) {
      if (!query || query.length < 2) {
        results.innerHTML = '';
        googleDiv.style.display = 'none';
        clearBtn.style.display = 'none';
        return;
      }

      clearBtn.style.display = 'block';
      const q = query.toLowerCase();

      const matched = posts.filter(p => {
        const text = `${p.title} ${p.excerpt} ${p.category} ${p.tags.join(' ')}`.toLowerCase();
        return text.includes(q);
      });

      if (matched.length > 0) {
        googleDiv.style.display = 'none';
        results.innerHTML = matched.slice(0, 10).map(p => `
          <a href="${p.slug}" style="
            display:flex; gap:12px; padding:12px;
            background:var(--bg-card); border:1px solid var(--border-color);
            border-radius:12px; text-decoration:none;
            transition: all 0.2s ease;
          " onmouseover="this.style.borderColor='var(--accent-primary)'"
             onmouseout="this.style.borderColor='var(--border-color)'">
            <img src="${p.image}" alt="" style="width:80px;height:60px;object-fit:cover;border-radius:8px;" />
            <div>
              <div style="font-size:0.75rem;color:var(--accent-primary);font-weight:600;">${p.category}</div>
              <div style="font-size:0.92rem;font-weight:600;color:var(--text-primary);line-height:1.3;">${p.title}</div>
            </div>
          </a>
        `).join('');
      } else {
        results.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:20px;">No results found on site</p>';
        googleDiv.style.display = 'block';
        googleLink.href = `https://www.google.com/search?q=site:anime-streaming-buzz.pages.dev+${encodeURIComponent(query)}`;
      }
    }

    input.addEventListener('input', (e) => search(e.target.value));
    clearBtn.addEventListener('click', () => {
      input.value = '';
      results.innerHTML = '';
      googleDiv.style.display = 'none';
      clearBtn.style.display = 'none';
      input.focus();
    });
  });
</script>
