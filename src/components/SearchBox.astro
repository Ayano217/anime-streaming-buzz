---

<div class="search-box" id="searchBox">
  <div class="search-input-wrap">
    <div class="search-icon-wrap">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <circle cx="11" cy="11" r="7"/>
        <path d="m20 20-3.5-3.5"/>
      </svg>
    </div>
    <input
      type="text"
      class="search-input"
      id="searchInput"
      placeholder="Search anime, manhwa, characters..."
      autocomplete="off"
      autofocus
    />
    <button class="search-clear-btn" id="searchClear" aria-label="Clear">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <div class="search-hint" id="searchHint">
    <span>💡 Try: </span>
    <button class="hint-tag" data-query="solo leveling">Solo Leveling</button>
    <button class="hint-tag" data-query="jujutsu kaisen">Jujutsu Kaisen</button>
    <button class="hint-tag" data-query="one piece">One Piece</button>
    <button class="hint-tag" data-query="manhwa">Manhwa</button>
    <button class="hint-tag" data-query="streaming">Streaming</button>
  </div>

  <div class="search-results" id="searchResults"></div>

  <div class="search-google" id="searchGoogle">
    <div class="google-box">
      <p class="google-text">Not found on site? Try searching the web:</p>
      <a id="googleSearchLink" href="#" target="_blank" rel="noopener" class="btn-primary">
        🔍 Search on Google
      </a>
    </div>
  </div>
</div>

<style>
  .search-box {
    max-width: 720px;
    margin: 0 auto;
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 22px;
    background: var(--bg-card);
    border: 2px solid var(--border-color);
    border-radius: var(--radius-xl);
    transition: all var(--transition-fast);
    position: relative;
  }

  .search-input-wrap:focus-within {
    border-color: var(--accent-primary);
    box-shadow: var(--glow-pink);
    background: var(--bg-card-hover);
  }

  .search-icon-wrap {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--transition-fast);
  }

  .search-input-wrap:focus-within .search-icon-wrap {
    color: var(--accent-primary);
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: 1.1rem;
    font-family: var(--font-main);
    outline: none;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-clear-btn {
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px;
    border-radius: 50%;
    display: none;
    transition: all var(--transition-fast);
  }

  .search-clear-btn:hover {
    color: var(--accent-primary);
    background: rgba(255, 51, 102, 0.1);
  }

  .search-clear-btn.visible {
    display: flex;
  }

  /* Hints */
  .search-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    flex-wrap: wrap;
  }

  .search-hint span {
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .hint-tag {
    padding: 5px 14px;
    border-radius: var(--radius-round);
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-family: var(--font-main);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .hint-tag:hover {
    border-color: var(--accent-primary);
    color: var(--accent-primary);
    background: rgba(255, 51, 102, 0.06);
  }

  /* Results */
  .search-results {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Google fallback */
  .search-google {
    margin-top: 24px;
    display: none;
  }

  .search-google.visible {
    display: block;
  }

  .google-box {
    text-align: center;
    padding: 28px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
  }

  .google-text {
    color: var(--text-secondary);
    margin-bottom: 16px;
    font-size: 0.92rem;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var input = document.getElementById('searchInput');
    var results = document.getElementById('searchResults');
    var googleDiv = document.getElementById('searchGoogle');
    var googleLink = document.getElementById('googleSearchLink');
    var clearBtn = document.getElementById('searchClear');
    var hintDiv = document.getElementById('searchHint');
    var posts = [];

    fetch('/search-index.json')
      .then(function(r) { return r.json(); })
      .then(function(data) { posts = data; })
      .catch(function() { posts = []; });

    function doSearch(query) {
      if (!query || query.length < 2) {
        results.innerHTML = '';
        googleDiv.className = 'search-google';
        clearBtn.className = 'search-clear-btn';
        hintDiv.style.display = 'flex';
        return;
      }

      clearBtn.className = 'search-clear-btn visible';
      hintDiv.style.display = 'none';
      var q = query.toLowerCase();

      var matched = posts.filter(function(p) {
        var text = (p.title + ' ' + p.excerpt + ' ' + p.category + ' ' + p.tags.join(' ')).toLowerCase();
        return text.indexOf(q) !== -1;
      });

      if (matched.length > 0) {
        googleDiv.className = 'search-google';
        results.innerHTML = matched.slice(0, 12).map(function(p) {
          return ''
            + '<a href="' + p.slug + '" class="search-result-card premium-card" style="display:flex;gap:14px;padding:14px;text-decoration:none;">'
            + '<img src="' + p.image + '" alt="" style="width:80px;height:65px;object-fit:cover;border-radius:var(--radius-md);flex-shrink:0;" loading="lazy" />'
            + '<div style="min-width:0;">'
            + '<div style="font-size:0.7rem;font-weight:700;color:var(--accent-primary);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">' + p.category + '</div>'
            + '<div style="font-size:0.92rem;font-weight:600;color:var(--text-primary);line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">' + p.title + '</div>'
            + '<div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px;">' + p.date + '</div>'
            + '</div>'
            + '</a>';
        }).join('');
      } else {
        results.innerHTML = ''
          + '<div style="text-align:center;padding:32px;color:var(--text-muted);">'
          + '<p style="font-size:2rem;margin-bottom:8px;">🔍</p>'
          + '<p>No results found for "<strong style="color:var(--text-primary);">' + query + '</strong>"</p>'
          + '</div>';
        googleDiv.className = 'search-google visible';
        googleLink.href = 'https://www.google.com/search?q=site:anime-streaming-buzz.pages.dev+' + encodeURIComponent(query);
      }
    }

    input.addEventListener('input', function(e) { doSearch(e.target.value); });

    clearBtn.addEventListener('click', function() {
      input.value = '';
      results.innerHTML = '';
      googleDiv.className = 'search-google';
      clearBtn.className = 'search-clear-btn';
      hintDiv.style.display = 'flex';
      input.focus();
    });

    document.querySelectorAll('.hint-tag').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var q = this.getAttribute('data-query');
        input.value = q;
        doSearch(q);
      });
    });
  });
</script>
