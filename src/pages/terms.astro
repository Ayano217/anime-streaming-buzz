---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Terms of Service">
  <Header />
  <main class="legal-page">
    <div class="container">
      <div class="legal-wrap glass">
        <h1 class="gradient-text">Terms of Service</h1>
        <p class="legal-date">Effective: July 2026</p>

        <h2>Usage</h2>
        <p>By using AniTube Buzz, you agree to these terms. Content is for informational and entertainment purposes only.</p>

        <h2>Content Ownership</h2>
        <p>Anime images belong to their creators and studios. Original articles are owned by AniTube Buzz. We use images under fair use for news reporting.</p>

        <h2>Prohibited Actions</h2>
        <ul>
          <li>Using the site for illegal purposes</li>
          <li>Scraping or redistributing content</li>
          <li>Disrupting site functionality</li>
        </ul>

        <h2>Third-Party Links</h2>
        <p>We link to official streaming platforms. We are not responsible for external site content.</p>

        <h2>Contact</h2>
        <p>Email: anitubebuzz@gmail.com</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page { padding-top: 40px; padding-bottom: 40px; }
  .legal-wrap { max-width: 800px; margin: 0 auto; padding: 40px; line-height: 1.8; }
  .legal-wrap h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 8px; }
  .legal-date { color: var(--text-muted); font-size: 0.88rem; margin-bottom: 32px; }
  .legal-wrap h2 { font-size: 1.3rem; font-weight: 700; margin: 28px 0 12px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; }
  .legal-wrap p { margin-bottom: 16px; color: var(--text-secondary); font-size: 0.95rem; }
  .legal-wrap ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .legal-wrap li { font-size: 0.92rem; color: var(--text-secondary); padding: 8px 14px; background: var(--bg-primary); border-radius: var(--radius-md); border: 1px solid var(--border-color); }
  @media (max-width: 600px) { .legal-wrap { padding: 24px; } .legal-wrap h1 { font-size: 1.7rem; } }
</style>
