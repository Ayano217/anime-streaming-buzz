---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import TrendingSection from '../components/TrendingSection.astro';
import CategorySection from '../components/CategorySection.astro';
import Sidebar from '../components/Sidebar.astro';
import FacebookVideos from '../components/FacebookVideos.astro';
import Footer from '../components/Footer.astro';

// Get all published posts sorted by date
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Helpers
const fmt = (d: string) =>
  new Date(d).toLocaleDateString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric'
  });
const rt = (b: string) =>
  `${Math.max(1, Math.ceil(b.split(/\s+/).length / 200))} min`;
const bt = (c: string) => {
  if (c === 'Streaming') return 'blue';
  if (c === 'Manhwa') return 'purple';
  if (c === 'Gaming') return 'gold';
  return 'pink';
};
const toCard = (p: any) => ({
  title: p.data.title,
  excerpt: p.data.excerpt,
  category: p.data.category,
  date: fmt(p.data.date),
  readTime: rt(p.body),
  image: p.data.image,
  slug: `/posts/${p.slug}`,
  badgeType: bt(p.data.category),
});

// Hero
const heroMain = sorted[0] ? toCard(sorted[0]) : null;
const heroSide = sorted.slice(1, 4).map(toCard);

// Trending
const trendingRaw = sorted.filter(p => p.data.trending).slice(0, 6);
const trendingFinal = (trendingRaw.length >= 3 ? trendingRaw : sorted.slice(0, 6))
  .map(p => ({
    title: p.data.title,
    category: p.data.category,
    slug: `/posts/${p.slug}`,
    date: fmt(p.data.date),
  }));

// Category posts
const latest = sorted.slice(0, 6).map(toCard);
const byCategory = (cat: string) =>
  sorted.filter(p => p.data.category === cat).slice(0, 3).map(toCard);
const animeRecaps = byCategory('Anime Recap');
const manhwa = byCategory('Manhwa');
const streaming = byCategory('Streaming');
const news = byCategory('News');
const gaming = byCategory('Gaming');

// Sidebar
const sidebarFormat = (posts: typeof sorted) =>
  posts.map(p => ({
    title: p.data.title,
    slug: `/posts/${p.slug}`,
    image: p.data.image,
    category: p.data.category,
    date: fmt(p.data.date),
  }));
const sidebarTrending = sidebarFormat(
  sorted.filter(p => p.data.trending).slice(0, 5)
);
const sidebarRecent = sidebarFormat(sorted.slice(0, 5));
---
<BaseLayout>
  <Header />
  <main>
    <!-- Hero -->
    <div class="container">
      <HeroSection mainPost={heroMain} sidePosts={heroSide} />
    </div>

    <!-- Trending Ticker + List -->
    <TrendingSection posts={trendingFinal} />

    <!-- Videos -->
    <FacebookVideos />

    <!-- Main Content + Sidebar -->
    <div class="main-layout container">
      <div class="content-area">
        {latest.length > 0 && (
          <CategorySection title="Latest" emoji="🆕" posts={latest} />
        )}
        {animeRecaps.length > 0 && (
          <CategorySection title="Anime Recap" emoji="🎬" posts={animeRecaps} />
        )}
        {manhwa.length > 0 && (
          <CategorySection title="Manhwa" emoji="📖" posts={manhwa} />
        )}
        {streaming.length > 0 && (
          <CategorySection title="Streaming" emoji="📺" posts={streaming} />
        )}
        {news.length > 0 && (
          <CategorySection title="News" emoji="📰" posts={news} />
        )}
        {gaming.length > 0 && (
          <CategorySection title="Gaming" emoji="🎮" posts={gaming} />
        )}
      </div>
      <Sidebar trendingPosts={sidebarTrending} recentPosts={sidebarRecent} />
    </div>
  </main>
  <Footer />
</BaseLayout>
<style>
  .main-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 32px;
    padding-top: 8px;
  }
  .content-area {
    min-width: 0;
  }
  @media (max-width: 1024px) {
    .main-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
