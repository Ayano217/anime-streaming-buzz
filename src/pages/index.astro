---

<BaseLayout>
  <Header />

  <main>
    <!-- Hero -->
    <HeroSection />

    <!-- Ad after hero -->
    <div class="container">
      <AdPlaceholder slot="after-hero" size="728x90" />
    </div>

    <!-- Trending -->
    <TrendingSection />

    <!-- Anime Recaps -->
    <CategorySection
      title="Anime Recaps"
      emoji="🎬"
      posts={animeRecaps}
    />

    <!-- Ad mid page -->
    <div class="container">
      <AdPlaceholder slot="mid-page" size="728x90" />
    </div>

    <!-- Manhwa Updates -->
    <CategorySection
      title="Manhwa & Webtoon"
      emoji="📖"
      posts={manhwaPosts}
    />

    <!-- Streaming News -->
    <CategorySection
      title="Streaming News"
      emoji="📺"
      posts={streamingNews}
    />

    <!-- Ad before gaming -->
    <div class="container">
      <AdPlaceholder slot="before-gaming" size="728x90" />
    </div>

    <!-- Gaming -->
    <CategorySection
      title="Anime Gaming"
      emoji="🎮"
      posts={gamingPosts}
    />
  </main>

  <Footer />
</BaseLayout>
