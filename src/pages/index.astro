---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import TrendingSection from '../components/TrendingSection.astro';
import CategorySection from '../components/CategorySection.astro';
import AdPlaceholder from '../components/AdPlaceholder.astro';
import Footer from '../components/Footer.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });

const readingTime = (body: string) => `${Math.max(1, Math.ceil(body.split(/\s+/).length / 200))} min read`;

const badgeTypeFromCategory = (category: string) => {
  if (category === 'Streaming') return 'blue';
  if (category === 'Manhwa') return 'purple';
  return 'pink';
};

const toCardPost = (post: any) => ({
  title: post.data.title,
  excerpt: post.data.excerpt,
  category: post.data.category,
  date: formatDate(post.data.date),
  readTime: readingTime(post.body),
  image: post.data.image,
  slug: `/posts/${post.slug}`,
  badgeType: badgeTypeFromCategory(post.data.category),
});

const featuredPosts = sortedPosts.filter(p => p.data.featured);
const mainHeroRaw = featuredPosts[0] || sortedPosts[0] || null;

const sideHeroRaw = [
  ...featuredPosts.filter(p => p.slug !== mainHeroRaw?.slug),
  ...sortedPosts.filter(p => p.slug !== mainHeroRaw?.slug),
].slice(0, 3);

const heroMain = mainHeroRaw ? toCardPost(mainHeroRaw) : null;
const heroSide = sideHeroRaw.map(toCardPost);

const trendingRaw = sortedPosts.filter(p => p.data.trending).slice(0, 5);
const fallbackTrendingRaw = sortedPosts.slice(0, 5);
const trendingPosts = (trendingRaw.length ? trendingRaw : fallbackTrendingRaw).map(post => ({
  title: post.data.title,
  category: post.data.category,
  slug: `/posts/${post.slug}`,
  date: formatDate(post.data.date),
}));

const latestPosts = sortedPosts.slice(0, 6).map(toCardPost);

const animeRecaps = sortedPosts
  .filter(p => p.data.category === 'Anime Recap')
  .slice(0, 3)
  .map(toCardPost);

const manhwaPosts = sortedPosts
  .filter(p => p.data.category === 'Manhwa')
  .slice(0, 3)
  .map(toCardPost);

const streamingPosts = sortedPosts
  .filter(p => p.data.category === 'Streaming')
  .slice(0, 3)
  .map(toCardPost);

const gamingPosts = sortedPosts
  .filter(p => p.data.category === 'Gaming')
  .slice(0, 3)
  .map(toCardPost);

const newsPosts = sortedPosts
  .filter(p => p.data.category === 'News')
  .slice(0, 3)
  .map(toCardPost);
---

<BaseLayout>
  <Header />

  <main>
    <HeroSection mainPost={heroMain} sidePosts={heroSide} />

    <div class="container">
      <AdPlaceholder slot="after-hero" size="728x90" />
    </div>

    <TrendingSection posts={trendingPosts} />

    {latestPosts.length > 0 && (
      <CategorySection
        title="Latest Articles"
        emoji="🆕"
        posts={latestPosts}
      />
    )}

    {animeRecaps.length > 0 && (
      <CategorySection
        title="Anime Recaps"
        emoji="🎬"
        posts={animeRecaps}
      />
    )}

    <div class="container">
      <AdPlaceholder slot="mid-page-1" size="728x90" />
    </div>

    {manhwaPosts.length > 0 && (
      <CategorySection
        title="Manhwa & Webtoon"
        emoji="📖"
        posts={manhwaPosts}
      />
    )}

    {streamingPosts.length > 0 && (
      <CategorySection
        title="Streaming News"
        emoji="📺"
        posts={streamingPosts}
      />
    )}

    <div class="container">
      <AdPlaceholder slot="mid-page-2" size="728x90" />
    </div>

    {newsPosts.length > 0 && (
      <CategorySection
        title="Anime News"
        emoji="📰"
        posts={newsPosts}
      />
    )}

    {gamingPosts.length > 0 && (
      <CategorySection
        title="Anime Gaming"
        emoji="🎮"
        posts={gamingPosts}
      />
    )}
  </main>

  <Footer />
</BaseLayout>
