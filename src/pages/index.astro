---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import TrendingSection from '../components/TrendingSection.astro';
import CategorySection from '../components/CategorySection.astro';
import AdPlaceholder from '../components/AdPlaceholder.astro';
import Footer from '../components/Footer.astro';

// Get all published posts
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Helper function
function formatPosts(posts: typeof sortedPosts) {
  return posts.map(post => ({
    title: post.data.title,
    excerpt: post.data.excerpt,
    category: post.data.category,
    date: post.data.date,
    readTime: `${Math.ceil(post.body.split(/\s+/).length / 200)} min read`,
    image: post.data.image,
    slug: `/posts/${post.slug}`,
  }));
}

// Filter by category
const animeRecaps = formatPosts(
  sortedPosts.filter(p => p.data.category === 'Anime Recap').slice(0, 3)
);

const manhwaPosts = formatPosts(
  sortedPosts.filter(p => p.data.category === 'Manhwa').slice(0, 3)
);

const streamingNews = formatPosts(
  sortedPosts.filter(p => p.data.category === 'Streaming').slice(0, 3)
);

const gamingPosts = formatPosts(
  sortedPosts.filter(p => p.data.category === 'Gaming').slice(0, 3)
);

const newsPosts = formatPosts(
  sortedPosts.filter(p => p.data.category === 'News').slice(0, 3)
);

const latestPosts = formatPosts(sortedPosts.slice(0, 6));
---

<BaseLayout>
  <Header />

  <main>
    <HeroSection />

    <div class="container">
      <AdPlaceholder slot="after-hero" size="728x90" />
    </div>

    <TrendingSection />

    <!-- Latest Posts -->
    {latestPosts.length > 0 && (
      <CategorySection
        title="Latest Articles"
        emoji="🆕"
        posts={latestPosts}
      />
    )}

    <!-- Anime Recaps -->
    {animeRecaps.length > 0 && (
      <CategorySection
        title="Anime Recaps"
        emoji="🎬"
        posts={animeRecaps}
      />
    )}

    <div class="container">
      <AdPlaceholder slot="mid-page-1" size="728x90" />
    </div>

    <!-- Manhwa -->
    {manhwaPosts.length > 0 && (
      <CategorySection
        title="Manhwa & Webtoon"
        emoji="📖"
        posts={manhwaPosts}
      />
    )}

    <!-- Streaming -->
    {streamingNews.length > 0 && (
      <CategorySection
        title="Streaming News"
        emoji="📺"
        posts={streamingNews}
      />
    )}

    <div class="container">
      <AdPlaceholder slot="mid-page-2" size="728x90" />
    </div>

    <!-- News -->
    {newsPosts.length > 0 && (
      <CategorySection
        title="Anime News"
        emoji="📰"
        posts={newsPosts}
      />
    )}

    <!-- Gaming -->
    {gamingPosts.length > 0 && (
      <CategorySection
        title="Anime Gaming"
        emoji="🎮"
        posts={gamingPosts}
      />
    )}
  </main>

  <Footer />
</BaseLayout>
