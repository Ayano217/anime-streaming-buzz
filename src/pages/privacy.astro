---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Privacy Policy">
  <Header />
  <main class="legal-page">
    <div class="container">
      <div class="legal-wrap glass">
        <h1 class="gradient-text">Privacy Policy</h1>
        <p class="legal-date">Effective: July 2026</p>

        <h2>What We Collect</h2>
        <p>AniTube Buzz collects minimal data. We use cookies for theme preferences and third-party advertising. We do not collect personal information unless you submit a comment.</p>

        <h2>Comments</h2>
        <p>Comments are stored locally in your browser. We do not store your email on our servers. Your first name is displayed publicly; email is never shown.</p>

        <h2>Advertising</h2>
        <p>We use Monetag for advertising. They may use cookies to serve relevant ads. See their privacy policy for details.</p>

        <h2>Analytics</h2>
        <p>We use Cloudflare Web Analytics which respects user privacy and does not use client-side tracking.</p>

        <h2>Your Rights</h2>
        <ul>
          <li>Access or delete your comment data (clear browser storage)</li>
          <li>Opt out of personalized ads (browser settings)</li>
          <li>Disable cookies in your browser</li>
        </ul>

        <h2>Contact</h2>
        <p>Email: anitubebuzz@gmail.com</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page { padding-top: 40px; padding-bottom: 40px; }
  .legal-wrap { max-width: 800px; margin: 0 auto; padding: 40px; line-height: 1.8; }
  .legal-wrap h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 8px; }
  .legal-date { color: var(--text-muted); font-size: 0.88rem; margin-bottom: 32px; }
  .legal-wrap h2 { font-size: 1.3rem; font-weight: 700; margin: 28px 0 12px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; }
  .legal-wrap p { margin-bottom: 16px; color: var(--text-secondary); font-size: 0.95rem; }
  .legal-wrap ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .legal-wrap li { font-size: 0.92rem; color: var(--text-secondary); padding: 8px 14px; background: var(--bg-primary); border-radius: var(--radius-md); border: 1px solid var(--border-color); }
  @media (max-width: 600px) { .legal-wrap { padding: 24px; } .legal-wrap h1 { font-size: 1.7rem; } }
</style>
