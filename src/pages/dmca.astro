---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="DMCA Policy">
  <Header />
  <main class="legal-page">
    <div class="container">
      <div class="legal-wrap glass">
        <h1 class="gradient-text">DMCA Policy</h1>

        <h2>Copyright</h2>
        <p>All anime and manga images, names, and trademarks belong to their respective creators. We use images under fair use for news reporting.</p>

        <h2>Filing a Complaint</h2>
        <p>If you believe content infringes your copyright, send a notice to:</p>
        <p><strong>anitubebuzz@gmail.com</strong></p>
        <p>Include: description of copyrighted work, URL of infringing content, your contact info, and a good faith statement.</p>

        <h2>Response</h2>
        <p>We respond to valid notices within 48 hours and remove infringing content promptly.</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page { padding-top: 40px; padding-bottom: 40px; }
  .legal-wrap { max-width: 800px; margin: 0 auto; padding: 40px; line-height: 1.8; }
  .legal-wrap h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 24px; }
  .legal-wrap h2 { font-size: 1.3rem; font-weight: 700; margin: 28px 0 12px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; }
  .legal-wrap p { margin-bottom: 16px; color: var(--text-secondary); font-size: 0.95rem; }
  @media (max-width: 600px) { .legal-wrap { padding: 24px; } .legal-wrap h1 { font-size: 1.7rem; } }
</style>
