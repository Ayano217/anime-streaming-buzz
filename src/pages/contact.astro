---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact Us">
  <Header />
  <main class="legal-page">
    <div class="container">
      <div class="legal-wrap glass">
        <div style="text-align:center; margin-bottom:32px;">
          <span style="font-size:3rem; display:block; margin-bottom:12px; animation: float 3s ease-in-out infinite;">📬</span>
          <h1 class="gradient-text">Contact Us</h1>
          <p style="color:var(--text-muted); font-size:1rem;">We'd love to hear from you</p>
        </div>

        <h2>General</h2>
        <p>📧 <strong>anitubebuzz@gmail.com</strong></p>

        <h2>Copyright</h2>
        <p>See our <a href="/dmca" style="color:var(--accent-primary);">DMCA Policy</a></p>

        <h2>Advertising</h2>
        <p>For partnership and advertising inquiries, email us.</p>

        <h2>Response Time</h2>
        <p>We typically respond within 24-48 hours.</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .legal-page { padding-top: 40px; padding-bottom: 40px; }
  .legal-wrap { max-width: 800px; margin: 0 auto; padding: 40px; line-height: 1.8; }
  .legal-wrap h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 8px; }
  .legal-wrap h2 { font-size: 1.3rem; font-weight: 700; margin: 28px 0 12px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; }
  .legal-wrap p { margin-bottom: 16px; color: var(--text-secondary); font-size: 0.95rem; }
  @media (max-width: 600px) { .legal-wrap { padding: 24px; } .legal-wrap h1 { font-size: 1.7rem; } }
</style>
