---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdPlaceholder from '../../components/AdPlaceholder.astro';
import NewsCard from '../../components/NewsCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Related posts
const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .filter(p =>
    p.data.category === post.data.category ||
    p.data.tags.some(tag => post.data.tags.includes(tag))
  )
  .slice(0, 3);

// Reading time
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.ceil(wordCount / 200);

// Date format
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  ogImage={post.data.image}
  ogType="article"
>
  <Header />

  <main class="post-page">
    <article class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <a href={`/category/${post.data.category.toLowerCase().replace(/\s+/g, '-')}`}>
          {post.data.category}
        </a>
        <span>/</span>
        <span class="current">{post.data.title}</span>
      </nav>

      <!-- Post Header -->
      <header class="post-header">
        <span class="badge badge-pink">{post.data.category}</span>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-excerpt">{post.data.excerpt}</p>

        <div class="post-meta">
          <div class="meta-left">
            <span class="meta-author">✍️ {post.data.author}</span>
            <span class="meta-dot">•</span>
            <span class="meta-date">📅 {formattedDate}</span>
            <span class="meta-dot">•</span>
            <span class="meta-read">⏱️ {readingTime} min read</span>
          </div>
        </div>

        <!-- Tags -->
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`} class="tag-link">
              #{tag}
            </a>
          ))}
        </div>
      </header>

      <!-- Featured Image -->
      <div class="post-hero-image">
        <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="eager" />
      </div>

      <!-- Ad after image -->
      <AdPlaceholder slot="post-top" size="728x90" />

      <!-- Post Content -->
      <div class="post-content prose">
        <Content />
      </div>

      <!-- Ad after content -->
      <AdPlaceholder slot="post-bottom" size="728x90" />

      <!-- Share buttons -->
      <div class="share-section">
        <h3>Share this article</h3>
        <div class="share-buttons">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
             target="_blank" rel="noopener" class="share-btn share-twitter">
            𝕏 Twitter
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
             target="_blank" rel="noopener" class="share-btn share-facebook">
            Facebook
          </a>
          <a href={`https://www.reddit.com/submit?url=${encodeURIComponent(Astro.url.href)}&title=${encodeURIComponent(post.data.title)}`}
             target="_blank" rel="noopener" class="share-btn share-reddit">
            Reddit
          </a>
        </div>
      </div>
    </article>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="related-section section">
        <div class="container">
          <h2 class="section-title">📌 Related Articles</h2>
          <div class="related-grid">
            {relatedPosts.map(rPost => (
              <NewsCard
                title={rPost.data.title}
                excerpt={rPost.data.excerpt}
                category={rPost.data.category}
                date={rPost.data.date}
                readTime={`${Math.ceil(rPost.body.split(/\s+/).length / 200)} min read`}
                image={rPost.data.image}
                slug={`/posts/${rPost.slug}`}
                badgeType="purple"
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .post-page {
    padding-top: calc(var(--header-height) + 20px);
  }

  /* Breadcrumb */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--text-secondary);
  }

  .breadcrumb a:hover {
    color: var(--accent-primary);
  }

  .breadcrumb .current {
    color: var(--text-muted);
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Post Header */
  .post-header {
    max-width: 800px;
    margin: 0 auto 30px;
    text-align: center;
  }

  .post-title {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 16px 0;
    line-height: 1.3;
  }

  .post-excerpt {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    margin-bottom: 16px;
  }

  .meta-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    justify-content: center;
  }

  .meta-dot {
    color: var(--border-color);
  }

  /* Tags */
  .post-tags {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .tag-link {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    background: rgba(123, 45, 255, 0.1);
    color: var(--accent-neon-purple);
    border: 1px solid rgba(123, 45, 255, 0.2);
    transition: all var(--transition-fast);
  }

  .tag-link:hover {
    background: rgba(123, 45, 255, 0.2);
    border-color: var(--accent-neon-purple);
  }

  /* Hero Image */
  .post-hero-image {
    max-width: 900px;
    margin: 0 auto 30px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .post-hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Post Content - Prose */
  .post-content {
    max-width: 760px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text-secondary);
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 40px 0 16px;
    color: var(--text-primary);
    padding-bottom: 8px;
    border-bottom: 2px solid var(--border-color);
  }

  .post-content :global(h3) {
    font-size: 1.3rem;
    font-weight: 600;
    margin: 30px 0 12px;
    color: var(--text-primary);
  }

  .post-content :global(p) {
    margin-bottom: 18px;
  }

  .post-content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 16px 0;
    padding-left: 24px;
  }

  .post-content :global(li) {
    margin-bottom: 8px;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--accent-primary);
    padding: 16px 24px;
    margin: 24px 0;
    background: var(--bg-card);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    color: var(--text-primary);
  }

  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
  }

  .post-content :global(th),
  .post-content :global(td) {
    padding: 12px 16px;
    text-align: left;
    border: 1px solid var(--border-color);
  }

  .post-content :global(th) {
    background: var(--bg-card);
    font-weight: 600;
    color: var(--text-primary);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border-color);
    margin: 40px 0;
  }

  .post-content :global(a) {
    color: var(--accent-tertiary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-content :global(a:hover) {
    color: var(--accent-primary);
  }

  /* Share */
  .share-section {
    max-width: 760px;
    margin: 40px auto;
    padding: 24px;
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    text-align: center;
  }

  .share-section h3 {
    font-size: 1rem;
    margin-bottom: 16px;
    color: var(--text-secondary);
  }

  .share-buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    padding: 10px 20px;
    border-radius: var(--radius-sm);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition-fast);
    border: 1px solid var(--border-color);
    color: var(--text-primary);
  }

  .share-twitter:hover {
    background: rgba(29, 161, 242, 0.15);
    border-color: #1da1f2;
    color: #1da1f2;
  }

  .share-facebook:hover {
    background: rgba(24, 119, 242, 0.15);
    border-color: #1877f2;
    color: #1877f2;
  }

  .share-reddit:hover {
    background: rgba(255, 69, 0, 0.15);
    border-color: #ff4500;
    color: #ff4500;
  }

  /* Related Grid */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .post-title {
      font-size: 1.6rem;
    }

    .post-excerpt {
      font-size: 1rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- JSON-LD Article Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": post.data.image,
  "datePublished": post.data.date,
  "dateModified": post.data.updated || post.data.date,
  "author": {
    "@type": "Person",
    "name": post.data.author
  },
  "publisher": {
    "@type": "Organization",
    "name": "AniTube Buzz",
    "logo": {
      "@type": "ImageObject",
      "url": "/favicon.svg"
    }
  }
})} />
