---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchBox from '../components/SearchBox.astro';
---

<BaseLayout title="Search">
  <Header />

  <main class="search-page">
    <div class="container">
      <div class="search-page-header">
        <h1>
          <span class="gradient-text">Search</span> AniTube Buzz
        </h1>
        <p>Find any anime, manhwa, character, or news article instantly</p>
      </div>
      <SearchBox />
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .search-page {
    padding-top: 40px;
    padding-bottom: 60px;
    min-height: 75vh;
  }

  .search-page-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .search-page-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin-bottom: 10px;
  }

  .search-page-header p {
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 600px) {
    .search-page-header h1 {
      font-size: 1.6rem;
    }
  }
</style>
