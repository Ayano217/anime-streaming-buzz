---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search — AniTube Buzz"
  description="Search all anime news, recaps, streaming guides, manhwa, and gaming content on AniTube Buzz."
>
  <div class="search-page">

    <!-- Search Hero -->
    <section class="search-hero">
      <div class="search-hero-inner">
        <h1 class="search-title">
          <span class="search-icon-big">🔍</span>
          <span class="glow-text">Search AniTube Buzz</span>
        </h1>
        <p class="search-subtitle">Find anime news, recaps, streaming guides, manhwa, and more</p>

        <!-- Search Input -->
        <div class="search-input-wrapper">
          <input
            type="text"
            id="search-input"
            class="search-input"
            placeholder="Search anime, manhwa, streaming..."
            autocomplete="off"
            autofocus
            aria-label="Search all content"
          />
          <button class="search-btn" id="search-btn" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </div>

        <!-- Category filter pills -->
        <div class="search-filters">
          <button class="filter-pill active" data-filter="all">All</button>
          <button class="filter-pill" data-filter="news">News</button>
          <button class="filter-pill" data-filter="anime-recap">Anime Recap</button>
          <button class="filter-pill" data-filter="manhwa">Manhwa</button>
          <button class="filter-pill" data-filter="streaming">Streaming</button>
          <button class="filter-pill" data-filter="gaming">Gaming</button>
        </div>
      </div>
    </section>

    <!-- Results Area -->
    <div class="search-content">

      <!-- Status bar -->
      <div class="search-status" id="search-status" aria-live="polite">
        <span id="status-text">Enter a keyword above to search all articles</span>
      </div>

      <!-- Results grid -->
      <div class="search-results" id="search-results" role="list"></div>

      <!-- Empty / No results state -->
      <div class="no-results" id="no-results" style="display:none;">
        <div class="no-results-icon">😢</div>
        <h2 id="no-results-title">No results found</h2>
        <p id="no-results-msg">We couldn't find anything matching your search on AniTube Buzz.</p>
        <div class="no-results-actions">
          <a
            id="google-fallback-link"
            href="#"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-google"
          >
            🌐 Search on Google
          </a>
          <a href="/" class="btn-home">← Back to Homepage</a>
        </div>
        <p class="no-results-tip">
          Tip: Try shorter keywords, check spelling, or browse by
          <a href="/category/news">category</a>.
        </p>
      </div>

      <!-- Initial / Welcome state -->
      <div class="search-welcome" id="search-welcome">
        <div class="welcome-grid">
          <a href="/category/news" class="welcome-card">
            <span class="welcome-emoji">📰</span>
            <span class="welcome-label">News</span>
          </a>
          <a href="/category/anime-recap" class="welcome-card">
            <span class="welcome-emoji">🎌</span>
            <span class="welcome-label">Anime Recap</span>
          </a>
          <a href="/category/manhwa" class="welcome-card">
            <span class="welcome-emoji">📖</span>
            <span class="welcome-label">Manhwa</span>
          </a>
          <a href="/category/streaming" class="welcome-card">
            <span class="welcome-emoji">▶️</span>
            <span class="welcome-label">Streaming</span>
          </a>
          <a href="/category/gaming" class="welcome-card">
            <span class="welcome-emoji">🎮</span>
            <span class="welcome-label">Gaming</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

<script is:inline>
(function () {
  'use strict';

  // ── State ──────────────────────────────────────────────
  let searchIndex = [];
  let currentFilter = 'all';
  let searchTimeout = null;
  let indexLoaded = false;

  // ── DOM refs ───────────────────────────────────────────
  const input       = document.getElementById('search-input');
  const statusText  = document.getElementById('status-text');
  const resultsEl   = document.getElementById('search-results');
  const noResults   = document.getElementById('no-results');
  const welcome     = document.getElementById('search-welcome');
  const googleLink  = document.getElementById('google-fallback-link');
  const filterPills = document.querySelectorAll('.filter-pill');

  // ── Load search index ──────────────────────────────────
  async function loadIndex() {
    if (indexLoaded) return;
    try {
      const res = await fetch('/search-index.json');
      if (!res.ok) throw new Error('Index fetch failed');
      searchIndex = await res.json();
      indexLoaded = true;
    } catch (err) {
      console.warn('Search index could not be loaded:', err);
      searchIndex = [];
      indexLoaded = true;
    }
  }

  // ── Highlight matching text ────────────────────────────
  function highlight(text, query) {
    if (!query || !text) return text || '';
    const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const regex = new RegExp(`(${escaped})`, 'gi');
    return text.replace(regex, '<mark class="hl">$1</mark>');
  }

  // ── Format date nicely ─────────────────────────────────
  function formatDate(dateStr) {
    if (!dateStr) return '';
    try {
      return new Date(dateStr).toLocaleDateString('en-US', {
        year: 'numeric', month: 'short', day: 'numeric'
      });
    } catch {
      return dateStr;
    }
  }

  // ── Run search ─────────────────────────────────────────
  async function runSearch() {
    await loadIndex();

    const rawQuery = input.value.trim();
    const query = rawQuery.toLowerCase();

    // Nothing typed — show welcome
    if (!rawQuery) {
      resultsEl.innerHTML = '';
      noResults.style.display = 'none';
      welcome.style.display = 'block';
      statusText.textContent = 'Enter a keyword above to search all articles';
      return;
    }

    welcome.style.display = 'none';

    // Filter by category first
    let pool = currentFilter === 'all'
      ? searchIndex
      : searchIndex.filter(p => {
          const cat = (p.category || '').toLowerCase().replace(/\s+/g, '-');
          return cat === currentFilter;
        });

    // Score each post
    const scored = pool
      .map((post) => {
        let score = 0;
        const title   = (post.title   || '').toLowerCase();
        const excerpt = (post.excerpt || '').toLowerCase();
        const cat     = (post.category || '').toLowerCase();
        const tags    = (post.tags    || []).join(' ').toLowerCase();

        if (title.includes(query))   score += 10;
        if (title.startsWith(query)) score += 5;
        if (excerpt.includes(query)) score += 4;
        if (cat.includes(query))     score += 3;
        if (tags.includes(query))    score += 2;

        // Word-by-word fallback
        const words = query.split(/\s+/).filter(w => w.length > 2);
        for (const word of words) {
          if (title.includes(word))   score += 2;
          if (excerpt.includes(word)) score += 1;
        }

        return { post, score };
      })
      .filter(({ score }) => score > 0)
      .sort((a, b) => b.score - a.score);

    // Update Google fallback link CORRECTLY (not "#")
    const encodedQ = encodeURIComponent(rawQuery + ' site:anime-streaming-buzz.pages.dev');
    googleLink.href = `https://www.google.com/search?q=${encodedQ}`;

    // No results
    if (scored.length === 0) {
      resultsEl.innerHTML = '';
      noResults.style.display = 'flex';
      document.getElementById('no-results-title').textContent =
        `No results for "${rawQuery}"`;
      document.getElementById('no-results-msg').textContent =
        currentFilter === 'all'
          ? `We couldn't find anything matching "${rawQuery}" on AniTube Buzz.`
          : `No results in the "${currentFilter}" category for "${rawQuery}". Try "All" categories.`;
      statusText.textContent = `0 results for "${rawQuery}"`;
      return;
    }

    // Show results
    noResults.style.display = 'none';
    statusText.textContent = `${scored.length} result${scored.length !== 1 ? 's' : ''} for "${rawQuery}"`;

    resultsEl.innerHTML = scored.map(({ post }) => {
      const safeTitle   = highlight(post.title   || 'Untitled', rawQuery);
      const safeExcerpt = highlight(
        (post.excerpt || '').substring(0, 180) + ((post.excerpt || '').length > 180 ? '...' : ''),
        rawQuery
      );
      const catDisplay = (post.category || 'General');
      const catSlug    = catDisplay.toLowerCase().replace(/\s+/g, '-');
      const imgSrc     = post.image || '/placeholder.jpg';
      const dateStr    = formatDate(post.date);

      return `
        <article class="result-card" role="listitem">
          <a href="/posts/${post.slug}" class="result-link">
            <div class="result-image-wrap">
              <img
                src="${imgSrc}"
                alt="${(post.imageAlt || post.title || '').replace(/"/g, '&quot;')}"
                class="result-image"
                loading="lazy"
                onerror="this.src='/placeholder.jpg'"
              />
              <span class="result-category-badge">${catDisplay}</span>
            </div>
            <div class="result-body">
              <h3 class="result-title">${safeTitle}</h3>
              <p class="result-excerpt">${safeExcerpt}</p>
              <div class="result-meta">
                <span class="result-date">${dateStr}</span>
                <span class="result-read">Read article →</span>
              </div>
            </div>
          </a>
        </article>
      `;
    }).join('');
  }

  // ── Event: input (debounced) ───────────────────────────
  input.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(runSearch, 250);
  });

  // ── Event: Enter key ───────────────────────────────────
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      clearTimeout(searchTimeout);
      runSearch();
    }
  });

  // ── Event: Search button ───────────────────────────────
  document.getElementById('search-btn').addEventListener('click', () => {
    clearTimeout(searchTimeout);
    runSearch();
  });

  // ── Event: Filter pills ────────────────────────────────
  filterPills.forEach((pill) => {
    pill.addEventListener('click', () => {
      filterPills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      currentFilter = pill.dataset.filter;
      if (input.value.trim()) runSearch();
    });
  });

  // ── Check for ?q= in URL ───────────────────────────────
  const urlParams = new URLSearchParams(window.location.search);
  const preQuery  = urlParams.get('q');
  if (preQuery) {
    input.value = preQuery;
    runSearch();
  }

  // ── Pre-load index on page load ───────────────────────
  loadIndex();

})();
</script>

<style>
  /* ── Page Container ── */
  .search-page {
    min-height: 100vh;
  }

  /* ── Search Hero ── */
  .search-hero {
    background: linear-gradient(
      135deg,
      rgba(0, 212, 255, 0.08) 0%,
      rgba(139, 0, 255, 0.12) 50%,
      rgba(255, 0, 128, 0.06) 100%
    );
    border-bottom: 1px solid rgba(139, 0, 255, 0.2);
    padding: 3rem 1.5rem 2.5rem;
    text-align: center;
  }

  .search-hero-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .search-title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 800;
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .search-icon-big {
    font-size: 0.8em;
  }

  .glow-text {
    background: linear-gradient(135deg, #fff 0%, #c084fc 50%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 15px rgba(139, 0, 255, 0.4));
  }

  .search-subtitle {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.95rem;
    margin: 0 0 1.5rem;
  }

  /* ── Search Input ── */
  .search-input-wrapper {
    display: flex;
    gap: 0;
    border-radius: 12px;
    overflow: hidden;
    border: 1.5px solid rgba(139, 0, 255, 0.5);
    background: rgba(10, 10, 20, 0.8);
    box-shadow: 0 0 20px rgba(139, 0, 255, 0.15);
    margin-bottom: 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .search-input-wrapper:focus-within {
    border-color: rgba(139, 0, 255, 0.9);
    box-shadow: 0 0 30px rgba(139, 0, 255, 0.3);
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #fff;
    font-size: 1rem;
    padding: 0.9rem 1.2rem;
    font-family: inherit;
  }

  .search-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .search-btn {
    background: linear-gradient(135deg, #8b00ff, #5500cc);
    border: none;
    color: #fff;
    padding: 0 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    min-width: 52px;
  }

  .search-btn:hover {
    background: linear-gradient(135deg, #9f1fff, #6600ff);
  }

  /* ── Filter Pills ── */
  .search-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  .filter-pill {
    background: rgba(139, 0, 255, 0.08);
    border: 1px solid rgba(139, 0, 255, 0.3);
    color: rgba(255, 255, 255, 0.6);
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .filter-pill:hover {
    background: rgba(139, 0, 255, 0.2);
    color: #fff;
  }

  .filter-pill.active {
    background: linear-gradient(135deg, #8b00ff, #5500cc);
    border-color: #8b00ff;
    color: #fff;
    box-shadow: 0 0 12px rgba(139, 0, 255, 0.35);
  }

  /* ── Content Area ── */
  .search-content {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* ── Status Bar ── */
  .search-status {
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(139, 0, 255, 0.15);
  }

  #status-text {
    color: rgba(255, 255, 255, 0.45);
    font-size: 0.85rem;
  }

  /* ── Results Grid ── */
  .search-results {
    display: grid;
    gap: 1rem;
  }

  .result-card {
    background: rgba(10, 10, 20, 0.6);
    border: 1px solid rgba(139, 0, 255, 0.15);
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .result-card:hover {
    border-color: rgba(139, 0, 255, 0.45);
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(139, 0, 255, 0.15);
  }

  .result-link {
    display: flex;
    gap: 0;
    text-decoration: none;
    color: inherit;
  }

  .result-image-wrap {
    position: relative;
    width: 160px;
    min-width: 160px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .result-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .result-card:hover .result-image {
    transform: scale(1.05);
  }

  .result-category-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: rgba(139, 0, 255, 0.85);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    backdrop-filter: blur(4px);
  }

  .result-body {
    padding: 1rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }

  .result-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.4rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-excerpt {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.83rem;
    line-height: 1.5;
    margin: 0 0 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .result-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .result-date {
    color: rgba(255, 255, 255, 0.35);
    font-size: 0.75rem;
  }

  .result-read {
    color: rgba(139, 0, 255, 0.8);
    font-size: 0.78rem;
    font-weight: 600;
  }

  /* ── Highlight mark ── */
  :global(.hl) {
    background: rgba(139, 0, 255, 0.35);
    color: #fff;
    border-radius: 2px;
    padding: 0 2px;
  }

  /* ── No Results State ── */
  .no-results {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 1.5rem;
    background: rgba(139, 0, 255, 0.04);
    border: 1px solid rgba(139, 0, 255, 0.12);
    border-radius: 16px;
  }

  .no-results-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .no-results h2 {
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 0.5rem;
    font-size: 1.3rem;
  }

  .no-results p {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 1.5rem;
    max-width: 420px;
    line-height: 1.5;
  }

  .no-results-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .btn-google {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.3rem;
    background: linear-gradient(135deg, #1a73e8, #0d47a1);
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.88rem;
    transition: all 0.2s;
    border: 1px solid rgba(26, 115, 232, 0.4);
  }

  .btn-google:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(26, 115, 232, 0.35);
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    padding: 0.6rem 1.3rem;
    background: rgba(139, 0, 255, 0.12);
    border: 1px solid rgba(139, 0, 255, 0.3);
    color: rgba(255, 255, 255, 0.8);
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.88rem;
    transition: all 0.2s;
  }

  .btn-home:hover {
    background: rgba(139, 0, 255, 0.22);
    color: #fff;
  }

  .no-results-tip {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.35);
  }

  .no-results-tip a {
    color: rgba(139, 0, 255, 0.7);
    text-decoration: none;
  }

  .no-results-tip a:hover {
    color: #8b00ff;
    text-decoration: underline;
  }

  /* ── Welcome Grid ── */
  .search-welcome {
    text-align: center;
  }

  .welcome-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .welcome-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    padding: 1.25rem 1.5rem;
    background: rgba(139, 0, 255, 0.07);
    border: 1px solid rgba(139, 0, 255, 0.2);
    border-radius: 12px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.75);
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.2s;
    min-width: 120px;
  }

  .welcome-card:hover {
    background: rgba(139, 0, 255, 0.18);
    border-color: rgba(139, 0, 255, 0.5);
    color: #fff;
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(139, 0, 255, 0.2);
  }

  .welcome-emoji {
    font-size: 1.75rem;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .result-link {
      flex-direction: column;
    }

    .result-image-wrap {
      width: 100%;
      min-width: unset;
      height: 160px;
    }

    .search-title {
      flex-direction: column;
      gap: 0.2rem;
    }

    .no-results-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
